---
/**
 * Payment History Page
 * All purchases with transaction details
 */
import Dashboard from '../../layouts/Dashboard.astro';
import SearchBar from '../../components/admin/SearchBar.astro';
import Pagination from '../../components/admin/Pagination.astro';
---

<Dashboard title="Payments" activeNav="purchases">
  <!-- Filters -->
  <div class="search-bar">
    <SearchBar placeholder="Search by user or transaction ID..." id="purchasesSearch" />
    <div class="filters">
      <select class="admin-input admin-select filter-select" id="typeFilter">
        <option value="">All Types</option>
        <option value="credit_pack">Credit Packs</option>
        <option value="subscription">Subscriptions</option>
      </select>
      <select class="admin-input admin-select filter-select" id="statusFilter">
        <option value="">All Status</option>
        <option value="completed">Completed</option>
        <option value="pending">Pending</option>
        <option value="failed">Failed</option>
        <option value="refunded">Refunded</option>
      </select>
      <input type="date" class="admin-input" id="dateFrom" />
      <input type="date" class="admin-input" id="dateTo" />
    </div>
  </div>

  <!-- Purchases Table -->
  <div class="card">
    <div class="purchases-table-wrapper">
      <table class="admin-table" id="purchasesTable">
        <thead>
          <tr>
            <th>User</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Transaction ID</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="purchasesTableBody">
          <tr>
            <td colspan="7" style="text-align: center; color: var(--admin-text-muted); padding: 48px;">
              <div class="loading-spinner" style="margin: 0 auto;"></div>
              <p style="margin-top: 12px;">Loading purchases...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <Pagination currentPage={1} totalPages={1} totalItems={0} id="purchasesPagination" />
  </div>
</Dashboard>

<style>
  .filters {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .filters input[type="date"] {
    width: 150px;
  }

  .user-cell {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .user-avatar {
    width: 32px;
    height: 32px;
    background: var(--admin-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 13px;
  }

  .user-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .user-phone {
    font-size: 12px;
    color: var(--admin-text-muted);
    font-family: monospace;
  }

  .amount-cell {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .meshulam-id {
    font-family: monospace;
    font-size: 12px;
    color: var(--admin-text-muted);
  }

  .meshulam-link {
    color: var(--admin-info);
    text-decoration: none;
  }

  .meshulam-link:hover {
    text-decoration: underline;
  }

  .type-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .type-detail {
    font-size: 12px;
    color: var(--admin-text-muted);
  }

  @media (max-width: 768px) {
    .filters input[type="date"] {
      width: 100%;
    }
  }
</style>

<script>
  let currentPage = 1;
  let currentSearch = '';
  let currentType = '';
  let currentStatus = '';
  let dateFrom = '';
  let dateTo = '';

  async function loadPurchases() {
    const tbody = document.getElementById('purchasesTableBody');
    if (!tbody) return;

    tbody.innerHTML = `
      <tr>
        <td colspan="7" style="text-align: center; padding: 48px;">
          <div class="loading-spinner" style="margin: 0 auto;"></div>
        </td>
      </tr>
    `;

    try {
      const params = new URLSearchParams({
        page: String(currentPage),
        ...(currentSearch && { search: currentSearch }),
        ...(currentType && { type: currentType }),
        ...(currentStatus && { status: currentStatus }),
        ...(dateFrom && { from: dateFrom }),
        ...(dateTo && { to: dateTo }),
      });

      const response = await fetch(`/api/admin/purchases?${params}`);
      if (!response.ok) throw new Error('Failed to load purchases');

      const data = await response.json();
      renderPurchases(data.purchases || []);
      updatePagination(data.page || 1, data.totalPages || 1, data.total || 0);
    } catch (error) {
      console.error('Error loading purchases:', error);
      tbody.innerHTML = `
        <tr>
          <td colspan="7" style="text-align: center; color: var(--admin-danger); padding: 48px;">
            Failed to load purchases. Please try again.
          </td>
        </tr>
      `;
    }
  }

  function renderPurchases(purchases: Array<Record<string, unknown>>) {
    const tbody = document.getElementById('purchasesTableBody');
    if (!tbody) return;

    if (purchases.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7">
            <div class="empty-state">
              <p class="empty-state-title">No purchases found</p>
              <p>Try adjusting your filters</p>
            </div>
          </td>
        </tr>
      `;
      return;
    }

    tbody.innerHTML = purchases.map((p) => `
      <tr data-purchase-id="${p.id}">
        <td>
          <div class="user-cell">
            <div class="user-avatar">${((p.user_name as string) || 'U').charAt(0).toUpperCase()}</div>
            <div class="user-info">
              <a href="/admin/users/${p.user_id}" style="font-weight: 500; color: var(--admin-primary); text-decoration: none;">
                ${p.user_name || 'Unknown'}
              </a>
              ${p.user_phone ? `<span class="user-phone">${p.user_phone}</span>` : ''}
            </div>
          </div>
        </td>
        <td>
          <div class="type-info">
            <span class="badge ${p.purchase_type === 'subscription' ? 'badge-success' : 'badge-info'}">
              ${p.purchase_type === 'subscription' ? 'Subscription' : 'Credit Pack'}
            </span>
            ${p.tier_name || p.pack_name ? `<span class="type-detail">${p.tier_name || p.pack_name}</span>` : ''}
          </div>
        </td>
        <td class="amount-cell">₪${(p.amount_ils as number).toLocaleString()}</td>
        <td>
          <span class="badge ${getStatusClass(p.status as string)}">${p.status}</span>
        </td>
        <td>
          <code style="font-size: 12px; color: var(--admin-text-muted);">
            ${p.transaction_id ? (p.transaction_id as string).slice(0, 16) + '...' : 'N/A'}
          </code>
          ${p.payment_gateway ? `<br><span style="font-size: 11px; color: var(--admin-text-muted);">(${p.payment_gateway})</span>` : ''}
        </td>
        <td style="white-space: nowrap; color: var(--admin-text-muted);">
          ${formatDateTime(p.created_at as string)}
        </td>
        <td>
          <span style="color: var(--admin-text-muted); font-size: 12px;">—</span>
        </td>
      </tr>
    `).join('');
  }

  function updatePagination(page: number, totalPages: number, total: number) {
    const pagination = document.getElementById('purchasesPagination');
    if (!pagination) return;

    const info = pagination.querySelector('.pagination-info');
    if (info) {
      const from = (page - 1) * 20 + 1;
      const to = Math.min(page * 20, total);
      info.textContent = `Showing ${from} to ${to} of ${total.toLocaleString()} results`;
    }
  }

  function formatDateTime(dateStr: string): string {
    return new Date(dateStr).toLocaleString('en-US', {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function getStatusClass(status: string): string {
    switch (status) {
      case 'completed': return 'badge-success';
      case 'pending': return 'badge-warning';
      case 'failed': return 'badge-danger';
      case 'refunded': return 'badge-info';
      case 'cancelled': return 'badge-neutral';
      default: return 'badge-neutral';
    }
  }

  // Event listeners
  window.addEventListener('admin:search', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail.inputId === 'purchasesSearch') {
      currentSearch = detail.query;
      currentPage = 1;
      loadPurchases();
    }
  });

  window.addEventListener('admin:page-change', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail.paginationId === 'purchasesPagination') {
      currentPage = detail.page;
      loadPurchases();
    }
  });

  document.getElementById('typeFilter')?.addEventListener('change', (e) => {
    currentType = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    loadPurchases();
  });

  document.getElementById('statusFilter')?.addEventListener('change', (e) => {
    currentStatus = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    loadPurchases();
  });

  document.getElementById('dateFrom')?.addEventListener('change', (e) => {
    dateFrom = (e.target as HTMLInputElement).value;
    currentPage = 1;
    loadPurchases();
  });

  document.getElementById('dateTo')?.addEventListener('change', (e) => {
    dateTo = (e.target as HTMLInputElement).value;
    currentPage = 1;
    loadPurchases();
  });

  // Initial load
  loadPurchases();
</script>
