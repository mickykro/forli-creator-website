---
/**
 * User Management Page
 * Searchable, filterable user table with actions
 */
import Dashboard from '../../layouts/Dashboard.astro';
import SearchBar from '../../components/admin/SearchBar.astro';
import Pagination from '../../components/admin/Pagination.astro';
---

<Dashboard title="Users" activeNav="users">
  <!-- Search and Filters -->
  <div class="search-bar">
    <SearchBar placeholder="Search by name, phone, or email..." id="userSearch" />
    <div class="filters">
      <select class="admin-input admin-select filter-select" id="tierFilter">
        <option value="">All Tiers</option>
        <option value="starter">Starter</option>
        <option value="growth">Growth</option>
        <option value="pro">Pro</option>
      </select>
      <select class="admin-input admin-select filter-select" id="statusFilter">
        <option value="">All Status</option>
        <option value="active">Active</option>
        <option value="trial">Trial</option>
        <option value="expired">Expired</option>
        <option value="cancelled">Cancelled</option>
      </select>
    </div>
  </div>

  <!-- User Table -->
  <div class="card">
    <div class="user-table-wrapper">
      <table class="admin-table" id="usersTable">
        <thead>
          <tr>
            <th>User</th>
            <th>Phone</th>
            <th>Credits</th>
            <th>Subscription</th>
            <th>Status</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="usersTableBody">
          <tr>
            <td colspan="7" style="text-align: center; color: var(--admin-text-muted); padding: 48px;">
              <div class="loading-spinner" style="margin: 0 auto;"></div>
              <p style="margin-top: 12px;">Loading users...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <Pagination currentPage={1} totalPages={1} totalItems={0} id="usersPagination" />
  </div>

  <!-- Add Credits Modal -->
  <div class="modal-overlay" id="addCreditsModal">
    <div class="modal">
      <div class="modal-header">
        <h3>Add Credits</h3>
        <button class="modal-close" id="closeCreditsModal">&times;</button>
      </div>
      <form id="addCreditsForm">
        <input type="hidden" id="creditsUserId" />
        <div class="form-group">
          <label for="creditsAmount">Amount (display value)</label>
          <input type="number" id="creditsAmount" class="admin-input" min="1" required />
          <p class="form-help">Enter the credit amount to add (e.g., 100 = 100 credits)</p>
        </div>
        <div class="form-group">
          <label for="creditsReason">Reason</label>
          <input type="text" id="creditsReason" class="admin-input" placeholder="e.g., Customer support compensation" required />
        </div>
        <div class="modal-actions">
          <button type="button" class="admin-btn admin-btn-secondary" id="cancelCreditsBtn">Cancel</button>
          <button type="submit" class="admin-btn admin-btn-primary">Add Credits</button>
        </div>
      </form>
    </div>
  </div>
</Dashboard>

<style>
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.open {
    display: flex;
  }

  .modal {
    background: var(--admin-surface);
    border-radius: var(--admin-radius-lg);
    width: 100%;
    max-width: 440px;
    margin: 20px;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 1px solid var(--admin-border);
  }

  .modal-header h3 {
    font-size: 16px;
    font-weight: 600;
  }

  .modal-close {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: var(--admin-text-muted);
    border-radius: var(--admin-radius);
  }

  .modal-close:hover {
    background: var(--admin-bg);
    color: var(--admin-text);
  }

  .modal form {
    padding: 20px;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 6px;
  }

  .form-help {
    font-size: 12px;
    color: var(--admin-text-muted);
    margin-top: 4px;
  }

  .modal-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--admin-border);
  }

  .user-cell {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .user-avatar {
    width: 32px;
    height: 32px;
    background: var(--admin-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 13px;
  }

  .actions-dropdown {
    position: relative;
  }

  .actions-menu {
    position: absolute;
    right: 0;
    top: 100%;
    min-width: 150px;
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    box-shadow: var(--admin-shadow-md);
    z-index: 50;
    display: none;
  }

  .actions-menu.open {
    display: block;
  }

  .actions-menu-item {
    display: block;
    width: 100%;
    padding: 8px 12px;
    font-size: 13px;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--admin-text);
    text-decoration: none;
  }

  .actions-menu-item:hover {
    background: var(--admin-bg);
  }

  .actions-menu-item.danger {
    color: var(--admin-danger);
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  let currentPage = 1;
  let currentSearch = '';
  let currentTier = '';
  let currentStatus = '';

  async function loadUsers() {
    const tbody = document.getElementById('usersTableBody');
    if (!tbody) return;

    tbody.innerHTML = `
      <tr>
        <td colspan="7" style="text-align: center; color: var(--admin-text-muted); padding: 48px;">
          <div class="loading-spinner" style="margin: 0 auto;"></div>
        </td>
      </tr>
    `;

    try {
      const params = new URLSearchParams({
        page: String(currentPage),
        ...(currentSearch && { search: currentSearch }),
        ...(currentTier && { tier: currentTier }),
        ...(currentStatus && { status: currentStatus }),
      });

      const response = await fetch(`/api/admin/users?${params}`);
      if (!response.ok) throw new Error('Failed to load users');

      const data = await response.json();
      renderUsers(data.users || []);
      updatePagination(data.page || 1, data.totalPages || 1, data.total || 0);
    } catch (error) {
      console.error('Error loading users:', error);
      tbody.innerHTML = `
        <tr>
          <td colspan="7" style="text-align: center; color: var(--admin-danger); padding: 48px;">
            Failed to load users. Please try again.
          </td>
        </tr>
      `;
    }
  }

  function renderUsers(users: Array<Record<string, unknown>>) {
    const tbody = document.getElementById('usersTableBody');
    if (!tbody) return;

    if (users.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7">
            <div class="empty-state">
              <p class="empty-state-title">No users found</p>
              <p>Try adjusting your search or filters</p>
            </div>
          </td>
        </tr>
      `;
      return;
    }

    tbody.innerHTML = users.map((user) => `
      <tr data-user-id="${user.id}">
        <td>
          <div class="user-cell">
            <div class="user-avatar">${((user.display_name as string) || 'U').charAt(0).toUpperCase()}</div>
            <span>${user.display_name || 'Unknown'}</span>
          </div>
        </td>
        <td style="font-family: monospace;">${user.phone_number || '-'}</td>
        <td style="font-variant-numeric: tabular-nums;">${formatCredits(user.credits_balance as number)}</td>
        <td>
          <span class="badge ${user.subscription_tier ? 'badge-info' : 'badge-neutral'}">
            ${user.subscription_tier || 'None'}
          </span>
        </td>
        <td>
          <span class="badge ${getStatusClass(user.subscription_status as string)}">
            ${user.subscription_status || 'None'}
          </span>
        </td>
        <td style="color: var(--admin-text-muted);">${formatDate(user.created_at as string)}</td>
        <td>
          <div class="actions-dropdown">
            <button class="admin-btn admin-btn-sm admin-btn-secondary actions-trigger" data-user-id="${user.id}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>
              </svg>
            </button>
            <div class="actions-menu" data-menu-for="${user.id}">
              <a href="/admin/users/${user.id}" class="actions-menu-item">View Details</a>
              <button class="actions-menu-item add-credits-btn" data-user-id="${user.id}" data-user-name="${user.display_name || 'Unknown'}">Add Credits</button>
              <button class="actions-menu-item danger ban-user-btn" data-user-id="${user.id}">Ban User</button>
            </div>
          </div>
        </td>
      </tr>
    `).join('');

    attachActionHandlers();
  }

  function attachActionHandlers() {
    // Toggle action menus
    document.querySelectorAll('.actions-trigger').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const userId = (btn as HTMLElement).dataset.userId;
        const menu = document.querySelector(`[data-menu-for="${userId}"]`);

        document.querySelectorAll('.actions-menu.open').forEach((m) => {
          if (m !== menu) m.classList.remove('open');
        });

        menu?.classList.toggle('open');
      });
    });

    // Add credits buttons
    document.querySelectorAll('.add-credits-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const userId = (btn as HTMLElement).dataset.userId;
        const userName = (btn as HTMLElement).dataset.userName;
        openAddCreditsModal(userId!, userName!);
      });
    });

    // Ban user buttons
    document.querySelectorAll('.ban-user-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const userId = (btn as HTMLElement).dataset.userId;
        if (confirm('Are you sure you want to ban this user?')) {
          // Implement ban logic
          alert('Ban functionality would be implemented here');
        }
      });
    });
  }

  function openAddCreditsModal(userId: string, userName: string) {
    const modal = document.getElementById('addCreditsModal');
    const userIdInput = document.getElementById('creditsUserId') as HTMLInputElement;

    if (modal && userIdInput) {
      userIdInput.value = userId;
      modal.classList.add('open');
    }
  }

  function updatePagination(page: number, totalPages: number, total: number) {
    const pagination = document.getElementById('usersPagination');
    if (!pagination) return;

    // Update pagination info
    const info = pagination.querySelector('.pagination-info');
    if (info) {
      const from = (page - 1) * 20 + 1;
      const to = Math.min(page * 20, total);
      info.textContent = `Showing ${from} to ${to} of ${total} results`;
    }

    pagination.dataset.current = String(page);
    pagination.dataset.total = String(totalPages);
  }

  function formatCredits(credits: number | undefined): string {
    if (credits === undefined) return '-';
    return (credits / 100).toLocaleString();
  }

  function formatDate(dateStr: string): string {
    return new Date(dateStr).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }

  function getStatusClass(status: string | undefined): string {
    switch (status) {
      case 'active': return 'badge-success';
      case 'trial': return 'badge-info';
      case 'cancelled': return 'badge-warning';
      case 'expired': return 'badge-danger';
      default: return 'badge-neutral';
    }
  }

  // Event listeners
  document.addEventListener('click', () => {
    document.querySelectorAll('.actions-menu.open').forEach((m) => m.classList.remove('open'));
  });

  window.addEventListener('admin:search', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail.inputId === 'userSearch') {
      currentSearch = detail.query;
      currentPage = 1;
      loadUsers();
    }
  });

  window.addEventListener('admin:page-change', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail.paginationId === 'usersPagination') {
      currentPage = detail.page;
      loadUsers();
    }
  });

  document.getElementById('tierFilter')?.addEventListener('change', (e) => {
    currentTier = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    loadUsers();
  });

  document.getElementById('statusFilter')?.addEventListener('change', (e) => {
    currentStatus = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    loadUsers();
  });

  // Modal handlers
  document.getElementById('closeCreditsModal')?.addEventListener('click', () => {
    document.getElementById('addCreditsModal')?.classList.remove('open');
  });

  document.getElementById('cancelCreditsBtn')?.addEventListener('click', () => {
    document.getElementById('addCreditsModal')?.classList.remove('open');
  });

  document.getElementById('addCreditsForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const userId = (document.getElementById('creditsUserId') as HTMLInputElement).value;
    const amount = Number((document.getElementById('creditsAmount') as HTMLInputElement).value);
    const reason = (document.getElementById('creditsReason') as HTMLInputElement).value;

    try {
      const response = await fetch('/api/admin/credits/grant', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userId,
          amount: amount * 100, // Convert to internal scale
          reason,
        }),
      });

      if (!response.ok) throw new Error('Failed to add credits');

      document.getElementById('addCreditsModal')?.classList.remove('open');
      (document.getElementById('addCreditsForm') as HTMLFormElement).reset();
      loadUsers();
    } catch (error) {
      alert('Failed to add credits. Please try again.');
    }
  });

  // Initial load
  loadUsers();
</script>
