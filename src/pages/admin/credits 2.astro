---
/**
 * Credit Transaction Log Page
 * Full transaction history with search and export
 */
import Dashboard from '../../layouts/Dashboard.astro';
import SearchBar from '../../components/admin/SearchBar.astro';
import Pagination from '../../components/admin/Pagination.astro';
---

<Dashboard title="Credits" activeNav="credits">
  <!-- Filters and Export -->
  <div class="search-bar">
    <SearchBar placeholder="Search by user name or transaction ID..." id="creditsSearch" />
    <div class="filters">
      <select class="admin-input admin-select filter-select" id="typeFilter">
        <option value="">All Types</option>
        <option value="credit">Credits Added</option>
        <option value="debit">Credits Used</option>
      </select>
      <select class="admin-input admin-select filter-select" id="sourceFilter">
        <option value="">All Sources</option>
        <option value="purchase">Purchase</option>
        <option value="subscription">Subscription</option>
        <option value="bonus">Bonus</option>
        <option value="refund">Refund</option>
        <option value="action_usage">Action Usage</option>
        <option value="admin_adjustment">Admin Adjustment</option>
      </select>
      <input type="date" class="admin-input" id="dateFrom" placeholder="From" />
      <input type="date" class="admin-input" id="dateTo" placeholder="To" />
      <button class="admin-btn admin-btn-secondary" id="exportCsvBtn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Export CSV
      </button>
    </div>
  </div>

  <!-- Transactions Table -->
  <div class="card">
    <div class="transaction-table-wrapper">
      <table class="admin-table" id="transactionsTable">
        <thead>
          <tr>
            <th>User</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Source</th>
            <th>Balance After</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody id="transactionsTableBody">
          <tr>
            <td colspan="6" style="text-align: center; color: var(--admin-text-muted); padding: 48px;">
              <div class="loading-spinner" style="margin: 0 auto;"></div>
              <p style="margin-top: 12px;">Loading transactions...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <Pagination currentPage={1} totalPages={1} totalItems={0} id="transactionsPagination" />
  </div>
</Dashboard>

<style>
  .filters {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .filters input[type="date"] {
    width: 150px;
  }

  .amount-cell {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .amount-cell.positive {
    color: var(--admin-success);
  }

  .amount-cell.negative {
    color: var(--admin-danger);
  }

  .source-cell {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .source-label {
    font-weight: 500;
  }

  .action-label {
    font-size: 12px;
    color: var(--admin-text-muted);
  }

  .description {
    font-size: 12px;
    color: var(--admin-text-muted);
    font-style: italic;
  }

  .user-link {
    color: var(--admin-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .user-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .filters input[type="date"] {
      width: 100%;
    }
  }
</style>

<script>
  let currentPage = 1;
  let currentSearch = '';
  let currentType = '';
  let currentSource = '';
  let dateFrom = '';
  let dateTo = '';

  async function loadTransactions() {
    const tbody = document.getElementById('transactionsTableBody');
    if (!tbody) return;

    tbody.innerHTML = `
      <tr>
        <td colspan="6" style="text-align: center; padding: 48px;">
          <div class="loading-spinner" style="margin: 0 auto;"></div>
        </td>
      </tr>
    `;

    try {
      const params = new URLSearchParams({
        page: String(currentPage),
        ...(currentSearch && { search: currentSearch }),
        ...(currentType && { type: currentType }),
        ...(currentSource && { source: currentSource }),
        ...(dateFrom && { from: dateFrom }),
        ...(dateTo && { to: dateTo }),
      });

      const response = await fetch(`/api/admin/credits?${params}`);
      if (!response.ok) throw new Error('Failed to load transactions');

      const data = await response.json();
      renderTransactions(data.transactions || []);
      updatePagination(data.page || 1, data.totalPages || 1, data.total || 0);
    } catch (error) {
      console.error('Error loading transactions:', error);
      tbody.innerHTML = `
        <tr>
          <td colspan="6" style="text-align: center; color: var(--admin-danger); padding: 48px;">
            Failed to load transactions. Please try again.
          </td>
        </tr>
      `;
    }
  }

  function renderTransactions(transactions: Array<Record<string, unknown>>) {
    const tbody = document.getElementById('transactionsTableBody');
    if (!tbody) return;

    if (transactions.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="6">
            <div class="empty-state">
              <p class="empty-state-title">No transactions found</p>
              <p>Try adjusting your filters</p>
            </div>
          </td>
        </tr>
      `;
      return;
    }

    tbody.innerHTML = transactions.map((tx) => `
      <tr data-transaction-id="${tx.id}">
        <td>
          <a href="/admin/users/${tx.user_id}" class="user-link">
            ${tx.user_name || 'Unknown'}
          </a>
        </td>
        <td>
          <span class="badge ${tx.transaction_type === 'credit' ? 'badge-success' : 'badge-danger'}">
            ${tx.transaction_type === 'credit' ? '+' : '-'}
          </span>
        </td>
        <td class="amount-cell ${tx.transaction_type === 'credit' ? 'positive' : 'negative'}">
          ${tx.transaction_type === 'credit' ? '+' : '-'}${formatCredits(tx.amount as number)}
        </td>
        <td>
          <div class="source-cell">
            <span class="source-label">${getSourceLabel(tx.source_type as string)}</span>
            ${tx.action_type ? `<span class="action-label">${getActionLabel(tx.action_type as string)}</span>` : ''}
            ${tx.description ? `<span class="description">${tx.description}</span>` : ''}
          </div>
        </td>
        <td style="font-variant-numeric: tabular-nums; color: var(--admin-text-muted);">
          ${formatCredits(tx.balance_after as number)}
        </td>
        <td style="white-space: nowrap; color: var(--admin-text-muted);">
          ${formatDateTime(tx.created_at as string)}
        </td>
      </tr>
    `).join('');
  }

  function updatePagination(page: number, totalPages: number, total: number) {
    const pagination = document.getElementById('transactionsPagination');
    if (!pagination) return;

    const info = pagination.querySelector('.pagination-info');
    if (info) {
      const from = (page - 1) * 50 + 1;
      const to = Math.min(page * 50, total);
      info.textContent = `Showing ${from} to ${to} of ${total.toLocaleString()} results`;
    }
  }

  function formatCredits(credits: number): string {
    return (credits / 100).toLocaleString();
  }

  function formatDateTime(dateStr: string): string {
    return new Date(dateStr).toLocaleString('en-US', {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function getSourceLabel(source: string): string {
    const labels: Record<string, string> = {
      purchase: 'Credit Pack Purchase',
      subscription: 'Subscription Credits',
      bonus: 'Bonus Credits',
      refund: 'Refund',
      action_usage: 'Action Usage',
      admin_adjustment: 'Admin Adjustment',
      migration: 'Data Migration',
    };
    return labels[source] || source;
  }

  function getActionLabel(action: string): string {
    const labels: Record<string, string> = {
      standard_image: 'Image Generation',
      carousel: 'Carousel Creation',
      standard_video: 'Video Generation',
      premium_video: 'Premium Video',
      text_consultation: 'Text Consultation',
    };
    return labels[action] || action;
  }

  async function exportToCsv() {
    try {
      const params = new URLSearchParams({
        format: 'csv',
        ...(currentSearch && { search: currentSearch }),
        ...(currentType && { type: currentType }),
        ...(currentSource && { source: currentSource }),
        ...(dateFrom && { from: dateFrom }),
        ...(dateTo && { to: dateTo }),
      });

      const response = await fetch(`/api/admin/credits/export?${params}`);
      if (!response.ok) throw new Error('Export failed');

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `credit-transactions-${new Date().toISOString().split('T')[0]}.csv`;
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
      a.remove();
    } catch (error) {
      alert('Failed to export CSV. Please try again.');
    }
  }

  // Event listeners
  window.addEventListener('admin:search', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail.inputId === 'creditsSearch') {
      currentSearch = detail.query;
      currentPage = 1;
      loadTransactions();
    }
  });

  window.addEventListener('admin:page-change', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail.paginationId === 'transactionsPagination') {
      currentPage = detail.page;
      loadTransactions();
    }
  });

  document.getElementById('typeFilter')?.addEventListener('change', (e) => {
    currentType = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    loadTransactions();
  });

  document.getElementById('sourceFilter')?.addEventListener('change', (e) => {
    currentSource = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    loadTransactions();
  });

  document.getElementById('dateFrom')?.addEventListener('change', (e) => {
    dateFrom = (e.target as HTMLInputElement).value;
    currentPage = 1;
    loadTransactions();
  });

  document.getElementById('dateTo')?.addEventListener('change', (e) => {
    dateTo = (e.target as HTMLInputElement).value;
    currentPage = 1;
    loadTransactions();
  });

  document.getElementById('exportCsvBtn')?.addEventListener('click', exportToCsv);

  // Initial load
  loadTransactions();
</script>
