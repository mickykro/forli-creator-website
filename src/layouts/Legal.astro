---
import Base from './Base.astro';
import { BUSINESS } from '../brand';

interface Props {
  title: string;
  description: string;
  heading: string;
  schema?: Record<string, unknown>;
}

const { title, description, heading, schema } = Astro.props;
const updatedAt = new Date().toLocaleDateString('he-IL');
---
<Base title={title} description={description} schema={schema}>
  <header class="legal-nav">
    <div class="container legal-nav-inner">
      <a href="/" class="brand" aria-label={`${BUSINESS.brandName} home`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-name">FORLY</span>
      </a>
      <a href="/" class="back-link">→ חזרה לדף הבית</a>
    </div>
  </header>

  <main class="legal" dir="rtl">
    <div class="container legal-container">
      <h1 class="legal-title">{heading}</h1>
      <p class="legal-meta">עודכן לאחרונה: {updatedAt}</p>
      <div class="legal-body">
        <slot />
      </div>
    </div>
  </main>

  <footer class="legal-footer">
    <div class="container legal-footer-inner">
      <div class="legal-footer-brand">
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-name">FORLY · {BUSINESS.legalName}</span>
      </div>
      <nav class="legal-footer-links" aria-label="Legal">
        <a href="/faq">שאלות ותשובות</a>
        <a href="/terms">תקנון אתר</a>
        <a href="/privacy">מדיניות פרטיות</a>
        <a href="/accessibility">הצהרת נגישות</a>
      </nav>
      <div class="legal-footer-contact">
        <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a>
        <a href={`tel:${BUSINESS.phoneE164}`} dir="ltr">{BUSINESS.phone}</a>
      </div>
      <p class="legal-footer-copy">© {new Date().getFullYear()} {BUSINESS.legalName}. כל הזכויות שמורות.</p>
    </div>
  </footer>
</Base>

<style>
  .legal-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 245, 248, 0.85);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid var(--line);
  }
  .legal-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    padding-bottom: 16px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: 0.18em;
    font-size: 14px;
    color: var(--ink);
  }
  .brand-mark {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: radial-gradient(circle at 30% 30%, var(--forli-pink-soft), var(--forli-pink) 60%, var(--forli-pink-deep));
    box-shadow: var(--glow-pink);
  }
  .back-link {
    font-size: 14px;
    color: var(--forli-pink-deep);
    font-weight: 600;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--forli-pink); }

  .legal {
    padding: 56px 0 80px;
    min-height: 70vh;
  }
  .legal-container {
    max-width: 820px;
  }
  .legal-title {
    font-size: clamp(32px, 4vw, 48px);
    color: var(--ink);
    margin-bottom: 8px;
  }
  .legal-meta {
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 36px;
  }
  .legal-body {
    color: var(--ink);
    line-height: 1.75;
    font-size: 16px;
  }
  .legal-body :global(section) { margin-bottom: 32px; }
  .legal-body :global(h2) {
    font-size: 22px;
    font-weight: 800;
    color: var(--ink);
    margin-bottom: 14px;
    margin-top: 8px;
  }
  .legal-body :global(h3) {
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
    margin-top: 18px;
    margin-bottom: 10px;
  }
  .legal-body :global(p) {
    margin-bottom: 12px;
    color: var(--ink-soft);
  }
  .legal-body :global(ul) {
    list-style: disc;
    padding-inline-start: 24px;
    margin-bottom: 12px;
    color: var(--ink-soft);
  }
  .legal-body :global(li) { margin-bottom: 6px; }
  .legal-body :global(strong) { color: var(--ink); }
  .legal-body :global(a) { color: var(--forli-pink-deep); border-bottom: 1px solid currentColor; }
  .legal-body :global(.contact-card) {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    padding: 20px 24px;
    border-radius: var(--radius-md);
    margin-top: 12px;
  }
  .legal-body :global(.contact-card p) { margin-bottom: 4px; }
  .legal-body :global(.disclaimer) {
    border-top: 1px solid var(--line);
    padding-top: 18px;
    margin-top: 24px;
    font-size: 13px;
    color: var(--ink-soft);
  }

  .legal-footer {
    background: var(--surface-soft);
    border-top: 1px solid var(--line);
    padding: 28px 0;
  }
  .legal-footer-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 18px 32px;
    align-items: center;
  }
  .legal-footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: 0.16em;
    font-size: 12px;
    color: var(--ink);
  }
  .legal-footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    justify-content: center;
    font-size: 13px;
    color: var(--ink-soft);
  }
  .legal-footer-links a:hover { color: var(--forli-pink-deep); }
  .legal-footer-contact {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 13px;
    color: var(--ink-soft);
    text-align: end;
  }
  .legal-footer-contact a:hover { color: var(--forli-pink-deep); }
  .legal-footer-copy {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--ink-soft);
    font-size: 12px;
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }
  @media (max-width: 720px) {
    .legal-footer-inner { grid-template-columns: 1fr; text-align: center; }
    .legal-footer-contact { text-align: center; }
    .legal-footer-links { justify-content: center; }
  }
</style>
