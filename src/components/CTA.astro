---
---
<section class="cta" id="cta" data-cta>
  <div class="ambient" aria-hidden="true"></div>
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>

  <div class="container cta-inner">
    <p class="eyebrow" data-cta-line>Forli · Private beta · Limited spots</p>
    <h2 class="cta-title" data-cta-line>
      Ready to stop<br />
      <span class="grad">losing customers?</span>
    </h2>
    <p class="cta-sub" data-cta-line>
      Join the private beta. Setup takes 15 minutes. The first week is on us.
      We will install Forli on your line, train her on your business, and stay on
      WhatsApp with you the whole way.
    </p>
    <div class="cta-actions" data-cta-line>
      <a href="https://wa.me/972000000000?text=Hi%20Forli" class="btn btn-primary">Join the beta</a>
      <a href="https://wa.me/972000000000?text=I%20have%20a%20question" class="btn btn-ghost">Got a question? WhatsApp us</a>
    </div>
    <p class="cta-foot" data-cta-line>Tel Aviv, Israel · Made for Israeli SMBs · Privacy by default</p>
  </div>
</section>

<footer class="footer">
  <div class="container footer-inner">
    <div class="brand">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-name">FORLI</span>
    </div>
    <p>© 2026 Forli. Made in Tel Aviv.</p>
  </div>
</footer>

<style>
  .cta {
    position: relative;
    padding: 200px 0 180px;
    overflow: hidden;
    background:
      linear-gradient(180deg, transparent, rgba(219, 107, 151, 0.08) 50%, transparent);
    isolation: isolate;
  }
  .ambient {
    position: absolute;
    inset: -10%;
    z-index: -1;
    background:
      radial-gradient(50% 50% at 50% 50%, rgba(219, 107, 151, 0.35), transparent 60%),
      radial-gradient(40% 40% at 70% 30%, rgba(127, 168, 155, 0.18), transparent 60%);
    filter: blur(60px);
    opacity: 0.85;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
    pointer-events: none;
  }
  .orb-1 {
    width: 520px;
    height: 520px;
    left: -120px;
    top: 10%;
    background: radial-gradient(circle, var(--forli-pink), transparent 70%);
    opacity: 0.45;
    animation: drift 14s ease-in-out infinite;
  }
  .orb-2 {
    width: 460px;
    height: 460px;
    right: -100px;
    bottom: 5%;
    background: radial-gradient(circle, var(--forli-pink-soft), transparent 70%);
    opacity: 0.35;
    animation: drift 16s ease-in-out -4s infinite;
  }
  @keyframes drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -30px) scale(1.05); }
  }

  .cta-inner {
    text-align: center;
    display: grid;
    gap: 22px;
    place-items: center;
    max-width: 820px;
  }
  .cta-title {
    font-size: clamp(44px, 7vw, 96px);
    font-weight: 900;
    color: var(--white);
    letter-spacing: -0.03em;
    line-height: 1;
    text-shadow: 0 0 60px rgba(219, 107, 151, 0.4);
  }
  .grad {
    background: linear-gradient(110deg, var(--forli-pink-soft) 0%, var(--forli-pink) 50%, var(--forli-pink-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cta-sub {
    color: rgba(255, 255, 255, 0.7);
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.55;
    max-width: 600px;
  }
  .cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .cta-foot {
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 28px 0;
    background: rgba(0, 0, 0, 0.25);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: rgba(255, 255, 255, 0.5);
    font-size: 13px;
  }
  .brand { display: flex; align-items: center; gap: 10px; font-family: var(--font-display); font-weight: 900; letter-spacing: 0.18em; font-size: 13px; color: var(--white); }
  .brand-mark { width: 22px; height: 22px; border-radius: 7px; background: radial-gradient(circle at 30% 30%, var(--forli-pink-soft), var(--forli-pink) 60%, var(--forli-pink-deep)); box-shadow: var(--glow-pink); }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const lines = gsap.utils.toArray<HTMLElement>('[data-cta-line]');
  if (lines.length) {
    gsap.from(lines, {
      y: 50,
      opacity: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.08,
      scrollTrigger: { trigger: '[data-cta]', start: 'top 70%' },
    });
  }
</script>
