---
import T from './T.astro';
import { BUSINESS, WHATSAPP_HELLO_URL, WHATSAPP_QUESTION_URL } from '../brand';

const year = new Date().getFullYear();
---
<section class="cta" id="cta" data-cta>
  <div class="ambient" aria-hidden="true"></div>
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>

  <div class="container cta-inner">
    <h2 class="cta-title" data-cta-line>
      <span class="l-he">מוכנים ליצור<br /><span class="grad">תוכן מהצ׳אט?</span></span>
      <span class="l-en">Ready to make<br /><span class="grad">content from chat?</span></span>
    </h2>
    <p class="cta-sub" data-cta-line>
      <span class="l-he">שלוש שאלות להצטרפות. שלחו הודעה ראשונה בעברית וצפו בתמונה חוזרת תוך שניות. אנחנו איתכם בוואטסאפ לכל הדרך — מהפוסט הראשון ועד הסרטון הראשון.</span>
      <span class="l-en">Three questions to onboard. Send your first Hebrew message and watch the image come back in seconds. We are on WhatsApp with you the whole way — from your first post to your first 3-shot video.</span>
    </p>
    <div class="cta-actions" data-cta-line>
      <a href={WHATSAPP_HELLO_URL} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        <T he="הצטרפו בוואטסאפ" en="Join the beta on WhatsApp" />
      </a>
      <a href={WHATSAPP_QUESTION_URL} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
        <T he="יש שאלה? כתבו לנו בוואטסאפ" en="Got a question? WhatsApp us" />
      </a>
    </div>
    <div class="cta-contact" data-cta-line>
      <a href={`mailto:${BUSINESS.email}`}>✉ {BUSINESS.email}</a>
      <a href={`tel:${BUSINESS.phoneE164}`} dir="ltr">📞 {BUSINESS.phone}</a>
    </div>
    <p class="cta-foot" data-cta-line>
      <T he="תל אביב, ישראל · לעסקים ישראליים · פרטיות כברירת מחדל" en="Tel Aviv, Israel · Built for Israeli SMBs · Privacy by default" />
    </p>
  </div>
</section>

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="brand">
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-name">FORLY · {BUSINESS.legalName}</span>
      </div>
      <nav class="footer-links" aria-label="Site links">
        <a href="/faq"><T he="שאלות ותשובות" en="FAQ" /></a>
        <a href="/terms"><T he="תקנון אתר" en="Terms" /></a>
        <a href="/privacy"><T he="מדיניות פרטיות" en="Privacy" /></a>
        <a href="/accessibility"><T he="הצהרת נגישות" en="Accessibility" /></a>
      </nav>
      <div class="footer-contact">
        <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a>
        <a href={`tel:${BUSINESS.phoneE164}`} dir="ltr">{BUSINESS.phone}</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>
        <T he={`© ${year} פורלי · ${BUSINESS.legalName}. נעשה בתל אביב.`} en={`© ${year} Forly · ${BUSINESS.legalName}. Made in Tel Aviv.`} />
      </p>
    </div>
  </div>
</footer>

<style>
  .cta {
    position: relative;
    padding: 200px 0 180px;
    overflow: hidden;
    background:
      linear-gradient(180deg, var(--surface), rgba(244, 163, 191, 0.10) 50%, var(--surface));
    isolation: isolate;
  }
  .ambient {
    position: absolute;
    inset: -10%;
    z-index: -1;
    background:
      radial-gradient(50% 50% at 50% 50%, rgba(219, 107, 151, 0.18), transparent 60%),
      radial-gradient(40% 40% at 70% 30%, rgba(127, 168, 155, 0.10), transparent 60%);
    filter: blur(60px);
    opacity: 0.95;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
    pointer-events: none;
  }
  .orb-1 {
    width: 520px;
    height: 520px;
    left: -120px;
    top: 10%;
    background: radial-gradient(circle, var(--forli-pink-soft), transparent 70%);
    opacity: 0.35;
    animation: drift 14s ease-in-out infinite;
  }
  .orb-2 {
    width: 460px;
    height: 460px;
    right: -100px;
    bottom: 5%;
    background: radial-gradient(circle, var(--forli-pink-soft), transparent 70%);
    opacity: 0.28;
    animation: drift 16s ease-in-out -4s infinite;
  }
  @keyframes drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -30px) scale(1.05); }
  }

  .cta-inner {
    text-align: center;
    display: grid;
    gap: 22px;
    place-items: center;
    max-width: 820px;
  }
  .cta-title {
    font-size: clamp(40px, 6vw, 84px);
    font-weight: 900;
    color: var(--ink);
    letter-spacing: -0.03em;
    line-height: 1;
    text-shadow: 0 0 60px rgba(219, 107, 151, 0.18);
  }
  .grad {
    background: linear-gradient(110deg, var(--forli-pink-soft) 0%, var(--forli-pink) 50%, var(--forli-pink-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cta-sub {
    color: var(--ink-soft);
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.55;
    max-width: 600px;
  }
  .cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .cta-contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px;
    margin-top: 18px;
    color: var(--ink-soft);
    font-size: 14px;
  }
  .cta-contact a { transition: color 0.2s ease; }
  .cta-contact a:hover { color: var(--forli-pink-deep); }

  .cta-foot {
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(26, 18, 32, 0.45);
  }

  .footer {
    border-top: 1px solid var(--line);
    padding: 32px 0 28px;
    background: var(--surface-soft);
    color: var(--ink-soft);
    font-size: 13px;
  }
  .footer-inner { display: grid; gap: 18px; }
  .footer-top {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px 32px;
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    justify-content: center;
  }
  .footer-links a { transition: color 0.2s ease; }
  .footer-links a:hover { color: var(--forli-pink-deep); }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: end;
  }
  .footer-contact a:hover { color: var(--forli-pink-deep); }
  .footer-bottom {
    border-top: 1px solid var(--line);
    padding-top: 14px;
    text-align: center;
    font-size: 12px;
  }
  @media (max-width: 720px) {
    .footer-top { grid-template-columns: 1fr; text-align: center; }
    .footer-contact { text-align: center; }
    .footer-links { justify-content: center; }
  }
  .brand { display: flex; align-items: center; gap: 10px; font-family: var(--font-display); font-weight: 900; letter-spacing: 0.16em; font-size: 13px; color: var(--ink); }
  .brand-mark { width: 22px; height: 22px; border-radius: 7px; background: radial-gradient(circle at 30% 30%, var(--forli-pink-soft), var(--forli-pink) 60%, var(--forli-pink-deep)); box-shadow: var(--glow-pink); }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const lines = gsap.utils.toArray<HTMLElement>('[data-cta-line]');
  if (lines.length) {
    gsap.from(lines, {
      y: 50,
      opacity: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.08,
      scrollTrigger: { trigger: '[data-cta]', start: 'top 70%' },
    });
  }
</script>
