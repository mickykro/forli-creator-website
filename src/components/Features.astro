---
import T from './T.astro';

const cards = [
  {
    label: { he: 'טקסט → תמונה', en: 'Text → Image' },
    title: { he: 'פוסט ממשפט אחד', en: 'Posts from a sentence' },
    body: {
      he: 'כתבו "תעשי לי פוסט לפיצרייה שלי". פורלי מחזירה את התמונה עם כיתוב בעברית והאשטגים — מוכן לפרסום.',
      en: 'Type "תעשי לי פוסט לפיצרייה שלי". Forly returns the image with a Hebrew caption and hashtags — ready to post.',
    },
    metric: 100,
    metricLabel: { he: 'כיתוב + האשטגים', en: 'Caption + hashtags' },
  },
  {
    label: { he: 'תמונה → תמונה', en: 'Image → Image' },
    title: { he: 'עריכה בלי פוטושופ', en: 'Edits without Photoshop' },
    body: {
      he: 'שלחו תמונה, כתבו "תוסיף לי כובע שמש". פורלי שומרת על הפנים שלכם ומשנה רק את מה שביקשתם.',
      en: 'Send a photo, write "תוסיף לי כובע שמש". Forly keeps your face recognizable and changes only what you asked for.',
    },
    metric: 96,
    metricLabel: { he: 'הפנים נשמרות', en: 'Identity preserved' },
  },
  {
    label: { he: 'טקסט → סרטון', en: 'Text → Video' },
    title: { he: 'סיפור ב-3 שוטים', en: '3-shot mini-stories' },
    body: {
      he: 'כל סרטון בנוי כך: פתיחה → תפנית → סיום. פורלי מייצרת את שלושת השוטים בריצה אחת, עם רציפות פנימית.',
      en: 'Every video follows setup → turn → payoff. Forly generates all three shots in one pass, with internal continuity.',
    },
    metric: 100,
    metricLabel: { he: 'מבנה סיפורי', en: 'Story arc shipped' },
  },
  {
    label: { he: 'תמונה → סרטון', en: 'Image → Video' },
    title: { he: 'תנועה על התמונה שלכם', en: 'Motion on top of your photo' },
    body: {
      he: 'שלחו תמונה. פורלי שואלת "איזו תנועה?" — והתשובה שלכם הופכת לסרטון 3 שוטים שמעוגן בתמונה.',
      en: 'Send the image. Forly asks "איזו תנועה?" — your reply becomes a 3-shot video anchored on your photo.',
    },
    metric: 90,
    metricLabel: { he: 'זמן יצירת תנועה', en: 'Motion turnaround' },
  },
  {
    label: { he: 'מערכת סגנונות', en: 'Tone system' },
    title: { he: '8 שפות ויזואליות', en: '8 visual DNAs' },
    body: {
      he: 'יוקרתי · משעשע · קולנועי · אנרגטי · אינטימי · דוקומנטרי · חולמני · נועז. בחרו ברירת מחדל, או החליפו בכל הודעה בעברית.',
      en: 'Luxurious · playful · cinematic · energetic · intimate · documentary · dreamy · bold. Pick one in your default, or override per message in Hebrew.',
    },
    metric: 100,
    metricLabel: { he: 'סגנונות זמינים', en: 'Tones supported' },
  },
  {
    label: { he: 'ישראל קודם כל', en: 'Israeli first' },
    title: { he: 'ים-תיכוני בברירת מחדל', en: 'Mediterranean by default' },
    body: {
      he: 'כל דמות שנוצרת מקבלת מאפיינים ים-תיכוניים ומזרח-תיכוניים — בנוי לעסקים ישראליים, לא הוצמד אחרי.',
      en: 'Every generated character has Middle Eastern and Mediterranean features by default — built for Israeli businesses, not retrofitted.',
    },
    metric: 100,
    metricLabel: { he: 'בנוי לישראל', en: 'Built for Israel' },
  },
];

const stats = [
  { value: 6, suffix: '', he: 'יכולות פעילות', en: 'Capabilities shipping' },
  { value: 8, suffix: '', he: 'סגנונות ויזואליים', en: 'Visual tones' },
  { value: 10, suffix: ' s', he: 'זמן יצירת תמונה', en: 'Image turnaround' },
  { value: 100, suffix: '%', he: 'עברית נייטיב', en: 'Hebrew native' },
];
---
<section class="features" id="features">
  <div class="container">
    <header class="features-head" data-reveal-stagger>
      <p class="eyebrow" data-reveal><T he="מה פורלי יוצרת" en="What Forly makes" /></p>
      <h2 class="features-title" data-reveal>
        <span class="l-he">סטודיו <span class="grad">יצירתי</span><br />שחי בצ׳אט שלכם.</span>
        <span class="l-en">A <span class="grad">creative studio</span><br />that lives in your chat.</span>
      </h2>
      <p class="features-sub" data-reveal>
        <span class="l-he">שש יכולות, רחוקות הודעה אחת בעברית — נוצרות על ידי פורלי, מוחזרות ישר לוואטסאפ.</span>
        <span class="l-en">Six capabilities, one Hebrew message away — generated by Forly, delivered straight back into WhatsApp.</span>
      </p>
    </header>

    <div class="grid">
      {cards.map((c, i) => (
        <article class="card" data-card style={`--i:${i}`}>
          <div class="card-glow" data-card-glow></div>
          <div class="card-content">
            <p class="card-label"><T he={c.label.he} en={c.label.en} /></p>
            <h3 class="card-title"><T he={c.title.he} en={c.title.en} /></h3>
            <p class="card-body"><T he={c.body.he} en={c.body.en} /></p>
            <div class="card-meter">
              <div class="meter-row">
                <span class="meter-label"><T he={c.metricLabel.he} en={c.metricLabel.en} /></span>
                <span class="meter-value" data-meter-value data-target={c.metric}>0%</span>
              </div>
              <div class="meter-track">
                <div class="meter-fill" data-meter-fill data-target={c.metric}></div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Letter-by-letter scramble quote — each language gets its own scramble target. -->
    <blockquote class="scramble" data-scramble-block>
      <p class="scramble-text">
        <span class="l-he" data-scramble>בלי אפליקציה. בלי דשבורד. בלי כלי עיצוב. רק וואטסאפ.</span>
        <span class="l-en" data-scramble>No app. No dashboard. No design tools. Just WhatsApp.</span>
      </p>
      <cite><T he="— התזה של פורלי v2" en="— The Forly v2 thesis" /></cite>
    </blockquote>

    <!-- Counter strip -->
    <ul class="stats" data-stats>
      {stats.map((s) => (
        <li class="stat">
          <span class="stat-num" data-counter data-target={s.value} data-suffix={s.suffix}>0</span>
          <span class="stat-label"><T he={s.he} en={s.en} /></span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .features {
    position: relative;
    padding: 160px 0 120px;
    background:
      radial-gradient(800px 600px at 20% 0%, rgba(219, 107, 151, 0.12), transparent 60%),
      radial-gradient(700px 500px at 80% 100%, rgba(127, 168, 155, 0.08), transparent 60%),
      var(--aubergine-deep);
  }
  .features-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 72px;
    display: grid;
    gap: 18px;
  }
  .features-title {
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    color: var(--white);
  }
  .grad {
    background: linear-gradient(110deg, var(--forli-pink-soft), var(--forli-pink), var(--forli-pink-deep));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .features-sub {
    color: rgba(255, 255, 255, 0.65);
    font-size: 17px;
    max-width: 560px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 1000px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .grid { grid-template-columns: 1fr; } }

  .card {
    position: relative;
    border-radius: var(--radius-md);
    padding: 1px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.4s ease;
  }
  .card-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      280px circle at var(--mx, 50%) var(--my, 50%),
      rgba(219, 107, 151, 0.35),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .card:hover .card-glow { opacity: 1; }
  .card:hover { transform: translateY(-4px); }

  .card-content {
    position: relative;
    z-index: 1;
    background: rgba(26, 18, 32, 0.7);
    backdrop-filter: blur(12px);
    border-radius: calc(var(--radius-md) - 1px);
    padding: 28px 26px 26px;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .card-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--forli-pink);
  }
  .card-title {
    font-size: 22px;
    color: var(--white);
    letter-spacing: -0.01em;
  }
  .card-body {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
    line-height: 1.55;
    flex: 1;
  }

  .card-meter { display: grid; gap: 8px; margin-top: 6px; }
  .meter-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }
  .meter-value { color: var(--white); font-weight: 600; }
  .meter-track {
    height: 4px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }
  .meter-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--forli-pink-soft), var(--forli-pink));
    border-radius: 4px;
    box-shadow: 0 0 12px rgba(219, 107, 151, 0.6);
  }

  .scramble {
    margin: 140px auto 120px;
    max-width: 920px;
    text-align: center;
    display: grid;
    gap: 18px;
  }
  .scramble-text {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.4vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    text-shadow: 0 0 60px rgba(219, 107, 151, 0.25);
  }
  .scramble-text .ch { display: inline-block; }
  .scramble-text .ch.live { color: var(--forli-pink); }
  .scramble cite {
    font-style: normal;
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .stats {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 36px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    backdrop-filter: blur(8px);
  }
  @media (max-width: 740px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat { display: grid; gap: 6px; text-align: center; }
  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.02em;
    text-shadow: 0 0 30px rgba(219, 107, 151, 0.4);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Reveal stagger on heading
  gsap.utils.toArray<HTMLElement>('[data-reveal-stagger]').forEach((group) => {
    const items = group.querySelectorAll<HTMLElement>('[data-reveal]');
    gsap.from(items, {
      y: 40,
      opacity: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.1,
      scrollTrigger: { trigger: group, start: 'top 80%' },
    });
  });

  // Card stagger reveal + meter fill on enter
  const cards = gsap.utils.toArray<HTMLElement>('[data-card]');
  if (cards.length) {
    gsap.from(cards, {
      y: 60,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.08,
      scrollTrigger: { trigger: cards[0].parentElement, start: 'top 75%' },
    });

    cards.forEach((card) => {
      const fill = card.querySelector<HTMLElement>('[data-meter-fill]');
      const value = card.querySelector<HTMLElement>('[data-meter-value]');
      if (!fill || !value) return;
      const target = Number(fill.dataset.target ?? 0);
      const proxy = { v: 0 };
      ScrollTrigger.create({
        trigger: card,
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.to(fill, { width: `${target}%`, duration: 1.4, ease: 'power3.out' });
          gsap.to(proxy, {
            v: target,
            duration: 1.4,
            ease: 'power3.out',
            onUpdate: () => {
              value.textContent = `${Math.round(proxy.v)}%`;
            },
          });
        },
      });
    });

    // Mouse-following neon glow on card hover
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      });
    });
  }

  // Letter-by-letter scramble reveal — applied independently to each language.
  const chars = '!<>-_\\/[]{}—=+*^?#________';
  document.querySelectorAll<HTMLElement>('[data-scramble]').forEach((scrambleEl) => {
    const original = scrambleEl.textContent ?? '';
    scrambleEl.innerHTML = original
      .split('')
      .map((c) => `<span class="ch" data-c="${c.replace(/"/g, '&quot;')}">${c === ' ' ? '&nbsp;' : c}</span>`)
      .join('');
    const spans = scrambleEl.querySelectorAll<HTMLElement>('.ch');

    ScrollTrigger.create({
      trigger: scrambleEl,
      start: 'top 75%',
      once: true,
      onEnter: () => {
        spans.forEach((span, i) => {
          const finalChar = span.dataset.c ?? '';
          if (finalChar === ' ') return;
          let frame = 0;
          const totalFrames = 14 + Math.floor(Math.random() * 8);
          const start = i * 22;
          setTimeout(() => {
            span.classList.add('live');
            const id = setInterval(() => {
              frame++;
              if (frame >= totalFrames) {
                span.textContent = finalChar;
                span.classList.remove('live');
                clearInterval(id);
              } else {
                span.textContent = chars[Math.floor(Math.random() * chars.length)];
              }
            }, 28);
          }, start);
        });
      },
    });
  });

  // Counter strip
  gsap.utils.toArray<HTMLElement>('[data-counter]').forEach((el) => {
    const target = Number(el.dataset.target ?? 0);
    const suffix = el.dataset.suffix ?? '';
    const obj = { v: 0 };
    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.to(obj, {
          v: target,
          duration: 1.8,
          ease: 'power3.out',
          onUpdate: () => {
            const n = target >= 1000 ? Math.round(obj.v).toLocaleString() : Math.round(obj.v).toString();
            el.textContent = `${n}${suffix}`;
          },
        });
      },
    });
  });
</script>
