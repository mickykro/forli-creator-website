---
const cards = [
  {
    label: 'Response',
    title: '24/7 instant reply',
    body: 'A real WhatsApp message lands within seconds of every missed call — at 2am, on Shabbat, in line at the bank.',
    metric: 96,
    metricLabel: 'Replies under 4 sec',
  },
  {
    label: 'Languages',
    title: 'Speaks four languages',
    body: 'Hebrew, English, Arabic, Russian. Forli detects the customer’s language from the first message and answers in kind.',
    metric: 100,
    metricLabel: 'Hebrew accuracy',
  },
  {
    label: 'Calendar',
    title: 'Books from your calendar',
    body: 'Connects to Google Calendar or Calendly, offers real availability, and writes the appointment back.',
    metric: 88,
    metricLabel: 'Booking conversion',
  },
  {
    label: 'Voice',
    title: 'Sounds like you',
    body: 'Trained on your services, your prices, your hours, your tone. Customers do not feel they hit a bot.',
    metric: 92,
    metricLabel: 'Sounds-like-you score',
  },
  {
    label: 'Alerts',
    title: 'Real-time on your phone',
    body: 'Every conversation lands in your phone with a full transcript, customer details, and one-tap takeover.',
    metric: 100,
    metricLabel: 'Conversations logged',
  },
  {
    label: 'Hand-off',
    title: 'Steps aside on cue',
    body: 'When the conversation gets personal or complex, Forli tags you in with a clean summary and lets you take it.',
    metric: 80,
    metricLabel: 'Auto-handled end-to-end',
  },
];

const stats = [
  { value: 1247, suffix: '+', label: 'Calls answered' },
  { value: 30, suffix: '%', label: 'Avg booking lift' },
  { value: 4, suffix: ' sec', label: 'Median response' },
  { value: 6, suffix: '', label: 'Pilot businesses' },
];
---
<section class="features" id="features">
  <div class="container">
    <header class="features-head" data-reveal-stagger>
      <p class="eyebrow" data-reveal>Why Forli</p>
      <h2 class="features-title" data-reveal>
        The <span class="grad">receptionist</span> every business<br />
        wishes they could afford.
      </h2>
      <p class="features-sub" data-reveal>
        Six features that turn missed calls into booked customers — without hiring,
        without scripts, without changing the way you work.
      </p>
    </header>

    <div class="grid">
      {cards.map((c, i) => (
        <article class="card" data-card style={`--i:${i}`}>
          <div class="card-glow" data-card-glow></div>
          <div class="card-content">
            <p class="card-label">{c.label}</p>
            <h3 class="card-title">{c.title}</h3>
            <p class="card-body">{c.body}</p>
            <div class="card-meter">
              <div class="meter-row">
                <span class="meter-label">{c.metricLabel}</span>
                <span class="meter-value" data-meter-value data-target={c.metric}>0%</span>
              </div>
              <div class="meter-track">
                <div class="meter-fill" data-meter-fill data-target={c.metric}></div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Letter-by-letter scramble quote -->
    <blockquote class="scramble" data-scramble-block>
      <p class="scramble-text" data-scramble>Voicemail is dead. WhatsApp answers. Forli is on the line.</p>
      <cite>— The new default for Israeli SMBs</cite>
    </blockquote>

    <!-- Counter strip -->
    <ul class="stats" data-stats>
      {stats.map((s) => (
        <li class="stat">
          <span class="stat-num" data-counter data-target={s.value} data-suffix={s.suffix}>0</span>
          <span class="stat-label">{s.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .features {
    position: relative;
    padding: 160px 0 120px;
    background:
      radial-gradient(800px 600px at 20% 0%, rgba(219, 107, 151, 0.12), transparent 60%),
      radial-gradient(700px 500px at 80% 100%, rgba(127, 168, 155, 0.08), transparent 60%),
      var(--aubergine-deep);
  }
  .features-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 72px;
    display: grid;
    gap: 18px;
  }
  .features-title {
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    color: var(--white);
  }
  .grad {
    background: linear-gradient(110deg, var(--forli-pink-soft), var(--forli-pink), var(--forli-pink-deep));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .features-sub {
    color: rgba(255, 255, 255, 0.65);
    font-size: 17px;
    max-width: 560px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 1000px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .grid { grid-template-columns: 1fr; } }

  .card {
    position: relative;
    border-radius: var(--radius-md);
    padding: 1px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.4s ease;
  }
  .card-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      280px circle at var(--mx, 50%) var(--my, 50%),
      rgba(219, 107, 151, 0.35),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .card:hover .card-glow { opacity: 1; }
  .card:hover { transform: translateY(-4px); }

  .card-content {
    position: relative;
    z-index: 1;
    background: rgba(26, 18, 32, 0.7);
    backdrop-filter: blur(12px);
    border-radius: calc(var(--radius-md) - 1px);
    padding: 28px 26px 26px;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .card-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--forli-pink);
  }
  .card-title {
    font-size: 22px;
    color: var(--white);
    letter-spacing: -0.01em;
  }
  .card-body {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
    line-height: 1.55;
    flex: 1;
  }

  .card-meter { display: grid; gap: 8px; margin-top: 6px; }
  .meter-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }
  .meter-value { color: var(--white); font-weight: 600; }
  .meter-track {
    height: 4px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }
  .meter-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--forli-pink-soft), var(--forli-pink));
    border-radius: 4px;
    box-shadow: 0 0 12px rgba(219, 107, 151, 0.6);
  }

  .scramble {
    margin: 140px auto 120px;
    max-width: 920px;
    text-align: center;
    display: grid;
    gap: 18px;
  }
  .scramble-text {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.4vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    text-shadow: 0 0 60px rgba(219, 107, 151, 0.25);
  }
  .scramble-text .ch { display: inline-block; }
  .scramble-text .ch.live { color: var(--forli-pink); }
  .scramble cite {
    font-style: normal;
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .stats {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 36px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    backdrop-filter: blur(8px);
  }
  @media (max-width: 740px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat { display: grid; gap: 6px; text-align: center; }
  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.02em;
    text-shadow: 0 0 30px rgba(219, 107, 151, 0.4);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Reveal stagger on heading
  gsap.utils.toArray<HTMLElement>('[data-reveal-stagger]').forEach((group) => {
    const items = group.querySelectorAll<HTMLElement>('[data-reveal]');
    gsap.from(items, {
      y: 40,
      opacity: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.1,
      scrollTrigger: { trigger: group, start: 'top 80%' },
    });
  });

  // Card stagger reveal + meter fill on enter
  const cards = gsap.utils.toArray<HTMLElement>('[data-card]');
  if (cards.length) {
    gsap.from(cards, {
      y: 60,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.08,
      scrollTrigger: { trigger: cards[0].parentElement, start: 'top 75%' },
    });

    cards.forEach((card) => {
      const fill = card.querySelector<HTMLElement>('[data-meter-fill]');
      const value = card.querySelector<HTMLElement>('[data-meter-value]');
      if (!fill || !value) return;
      const target = Number(fill.dataset.target ?? 0);
      const proxy = { v: 0 };
      ScrollTrigger.create({
        trigger: card,
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.to(fill, { width: `${target}%`, duration: 1.4, ease: 'power3.out' });
          gsap.to(proxy, {
            v: target,
            duration: 1.4,
            ease: 'power3.out',
            onUpdate: () => {
              value.textContent = `${Math.round(proxy.v)}%`;
            },
          });
        },
      });
    });

    // Mouse-following neon glow on card hover
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      });
    });
  }

  // Letter-by-letter scramble reveal
  const scrambleEl = document.querySelector<HTMLElement>('[data-scramble]');
  if (scrambleEl) {
    const original = scrambleEl.textContent ?? '';
    const chars = '!<>-_\\/[]{}—=+*^?#________';
    scrambleEl.innerHTML = original
      .split('')
      .map((c) => `<span class="ch" data-c="${c.replace(/"/g, '&quot;')}">${c === ' ' ? '&nbsp;' : c}</span>`)
      .join('');
    const spans = scrambleEl.querySelectorAll<HTMLElement>('.ch');

    ScrollTrigger.create({
      trigger: scrambleEl,
      start: 'top 75%',
      once: true,
      onEnter: () => {
        spans.forEach((span, i) => {
          const finalChar = span.dataset.c ?? '';
          if (finalChar === ' ') return;
          let frame = 0;
          const totalFrames = 14 + Math.floor(Math.random() * 8);
          const start = i * 22;
          setTimeout(() => {
            span.classList.add('live');
            const id = setInterval(() => {
              frame++;
              if (frame >= totalFrames) {
                span.textContent = finalChar;
                span.classList.remove('live');
                clearInterval(id);
              } else {
                span.textContent = chars[Math.floor(Math.random() * chars.length)];
              }
            }, 28);
          }, start);
        });
      },
    });
  }

  // Counter strip
  gsap.utils.toArray<HTMLElement>('[data-counter]').forEach((el) => {
    const target = Number(el.dataset.target ?? 0);
    const suffix = el.dataset.suffix ?? '';
    const obj = { v: 0 };
    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.to(obj, {
          v: target,
          duration: 1.8,
          ease: 'power3.out',
          onUpdate: () => {
            const n = target >= 1000 ? Math.round(obj.v).toLocaleString() : Math.round(obj.v).toString();
            el.textContent = `${n}${suffix}`;
          },
        });
      },
    });
  });
</script>
