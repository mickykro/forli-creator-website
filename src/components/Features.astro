---
import T from './T.astro';
import RadialOrbitalTimeline, { type TimelineItem } from './RadialOrbitalTimeline.astro';

// 6 capabilities Forly ships. Each node is a distinct generation pipeline.
// Connections show which capabilities pair up: image ↔ image-edit,
// video ↔ image-to-video, plus carousels/websites that compose the others.
const processSteps: TimelineItem[] = [
  {
    id: 1,
    iconKey: 'image',
    he: {
      title: 'יצירת תמונה',
      date: '5–10 שניות',
      content: 'משפט אחד בעברית הופך לתמונה מוכנה לפרסום, עם כיתוב והאשטגים מותאמים לטון של העסק שלכם.',
    },
    en: {
      title: 'Create image',
      date: '5–10 seconds',
      content: 'One Hebrew sentence becomes a ready-to-post image, with caption and hashtags matched to your brand voice.',
    },
    status: 'completed',
    relatedIds: [2, 5],
    progress: 100,
  },
  {
    id: 2,
    iconKey: 'image-edit',
    he: {
      title: 'תמונה לתמונה',
      date: 'בלי פוטושופ',
      content: 'שלחו תמונה ובקשה — "תוסיף לי כובע", "תשני את הצבע", "תחליפי רקע" — והפנים שלכם נשארות מזוהות.',
    },
    en: {
      title: 'Image to image',
      date: 'No Photoshop',
      content: 'Send a photo and a request — "add a hat", "change the color", "swap the background" — and your face stays recognizable.',
    },
    status: 'completed',
    relatedIds: [1],
    progress: 96,
  },
  {
    id: 3,
    iconKey: 'video',
    he: {
      title: 'יצירת סרטון',
      date: '10–15 שניות וידאו',
      content: 'משפט אחד הופך לסרטון מיני בן 3 שוטים: פתיחה → תפנית → סיום. רציפות פנימית, סגנון לבחירה.',
    },
    en: {
      title: 'Create video',
      date: '10–15 second clip',
      content: 'One sentence becomes a 3-shot mini-story: setup → turn → payoff. Internal continuity, tone of your choice.',
    },
    status: 'completed',
    relatedIds: [4],
    progress: 90,
  },
  {
    id: 4,
    iconKey: 'video-motion',
    he: {
      title: 'תמונה לסרטון',
      date: 'תנועה בהזמנה',
      content: 'שלחו תמונה. פורלי שואלת "איזו תנועה?" — והתשובה שלכם הופכת לסרטון 3 שוטים שמעוגן בתמונה המקורית.',
    },
    en: {
      title: 'Image to video',
      date: 'Motion on demand',
      content: 'Send an image. Forly asks "what motion?" — your reply becomes a 3-shot video anchored on your photo.',
    },
    status: 'in-progress',
    relatedIds: [3],
    progress: 75,
  },
  {
    id: 5,
    iconKey: 'carousel',
    he: {
      title: 'קרוסלה',
      date: 'אינסטגרם',
      content: '3–5 תמונות מחוברות, מעוצבות לפוסט החלקה — מספרות סיפור אחד, פריים אחר פריים, עם כיתובים מותאמים.',
    },
    en: {
      title: 'Carousel',
      date: 'Instagram swipe',
      content: '3–5 connected images designed as a swipe post — they tell one story frame by frame, captions included.',
    },
    status: 'in-progress',
    relatedIds: [1, 6],
    progress: 60,
  },
  {
    id: 6,
    iconKey: 'website',
    he: {
      title: 'אתר עסק',
      date: 'דף נחיתה',
      content: 'דף עסק נקי שנבנה אוטומטית מהפרופיל שלכם ומכל התוכן שיצרתם — מתעדכן בהודעה אחת.',
    },
    en: {
      title: 'Website',
      date: 'Landing page',
      content: 'A clean business page built automatically from your profile and the content you\'ve created — updates with a single message.',
    },
    status: 'pending',
    relatedIds: [5, 1, 3],
    progress: 35,
  },
];

const cards = [
  {
    label: { he: 'טקסט → תמונה', en: 'Text → Image' },
    title: { he: 'פוסט ממשפט אחד', en: 'Posts from a sentence' },
    body: {
      he: 'כתבו "תעשי לי פוסט לפיצרייה שלי". פורלי מחזירה את התמונה עם כיתוב בעברית והאשטגים — מוכן לפרסום.',
      en: 'Type "תעשי לי פוסט לפיצרייה שלי". Forly returns the image with a Hebrew caption and hashtags — ready to post.',
    },
    metric: 100,
    metricLabel: { he: 'כיתוב + האשטגים', en: 'Caption + hashtags' },
  },
  {
    label: { he: 'תמונה → תמונה', en: 'Image → Image' },
    title: { he: 'עריכה בלי פוטושופ', en: 'Edits without Photoshop' },
    body: {
      he: 'שלחו תמונה, כתבו "תוסיף לי כובע שמש". פורלי שומרת על הפנים שלכם ומשנה רק את מה שביקשתם.',
      en: 'Send a photo, write "תוסיף לי כובע שמש". Forly keeps your face recognizable and changes only what you asked for.',
    },
    metric: 96,
    metricLabel: { he: 'הפנים נשמרות', en: 'Identity preserved' },
  },
  {
    label: { he: 'טקסט → סרטון', en: 'Text → Video' },
    title: { he: 'סיפור ב-3 שוטים', en: '3-shot mini-stories' },
    body: {
      he: 'כל סרטון בנוי כך: פתיחה → תפנית → סיום. פורלי מייצרת את שלושת השוטים בריצה אחת, עם רציפות פנימית.',
      en: 'Every video follows setup → turn → payoff. Forly generates all three shots in one pass, with internal continuity.',
    },
    metric: 100,
    metricLabel: { he: 'מבנה סיפורי', en: 'Story arc shipped' },
  },
  {
    label: { he: 'תמונה → סרטון', en: 'Image → Video' },
    title: { he: 'תנועה על התמונה שלכם', en: 'Motion on top of your photo' },
    body: {
      he: 'שלחו תמונה. פורלי שואלת "איזו תנועה?" — והתשובה שלכם הופכת לסרטון 3 שוטים שמעוגן בתמונה.',
      en: 'Send the image. Forly asks "איזו תנועה?" — your reply becomes a 3-shot video anchored on your photo.',
    },
    metric: 90,
    metricLabel: { he: 'זמן יצירת תנועה', en: 'Motion turnaround' },
  },
  {
    label: { he: 'מערכת סגנונות', en: 'Tone system' },
    title: { he: '8 שפות ויזואליות', en: '8 visual DNAs' },
    body: {
      he: 'יוקרתי · משעשע · קולנועי · אנרגטי · אינטימי · דוקומנטרי · חולמני · נועז. בחרו ברירת מחדל, או החליפו בכל הודעה בעברית.',
      en: 'Luxurious · playful · cinematic · energetic · intimate · documentary · dreamy · bold. Pick one in your default, or override per message in Hebrew.',
    },
    metric: 100,
    metricLabel: { he: 'סגנונות זמינים', en: 'Tones supported' },
  },
  {
    label: { he: 'ישראל קודם כל', en: 'Israeli first' },
    title: { he: 'ים-תיכוני בברירת מחדל', en: 'Mediterranean by default' },
    body: {
      he: 'כל דמות שנוצרת מקבלת מאפיינים ים-תיכוניים ומזרח-תיכוניים — בנוי לעסקים ישראליים, לא הוצמד אחרי.',
      en: 'Every generated character has Middle Eastern and Mediterranean features by default — built for Israeli businesses, not retrofitted.',
    },
    metric: 100,
    metricLabel: { he: 'בנוי לישראל', en: 'Built for Israel' },
  },
];

type StatAccent = 'pink' | 'violet' | 'amber' | 'sage';
type StatIcon = 'spark' | 'palette' | 'clock' | 'globe';
const stats: {
  value: number;
  suffix: string;
  accent: StatAccent;
  icon: StatIcon;
  he: string;
  en: string;
}[] = [
  { value: 6, suffix: '', accent: 'pink', icon: 'spark', he: 'יכולות פעילות', en: 'Capabilities shipping' },
  { value: 8, suffix: '', accent: 'violet', icon: 'palette', he: 'סגנונות ויזואליים', en: 'Visual tones' },
  { value: 10, suffix: ' s', accent: 'amber', icon: 'clock', he: 'זמן יצירת תמונה', en: 'Image turnaround' },
  { value: 100, suffix: '%', accent: 'sage', icon: 'globe', he: 'עברית נייטיב', en: 'Hebrew native' },
];
---
<RadialOrbitalTimeline
  items={processSteps}
  eyebrowHe="היכולות של פורלי"
  eyebrowEn="What Forly can do"
  headingHe="שש יכולות. הודעה אחת בעברית."
  headingEn="Six capabilities. One Hebrew message."
/>
<section class="features" id="features">
  <div class="container">
    <header class="features-head" data-reveal-stagger>
      <p class="eyebrow" data-reveal><T he="מה פורלי יוצרת" en="What Forly makes" /></p>
      <h2 class="features-title" data-reveal>
        <span class="l-he">סטודיו <span class="grad">יצירתי</span><br />שחי בצ׳אט שלכם.</span>
        <span class="l-en">A <span class="grad">creative studio</span><br />that lives in your chat.</span>
      </h2>
      <p class="features-sub" data-reveal>
        <span class="l-he">שש יכולות, רחוקות הודעה אחת בעברית — נוצרות על ידי פורלי, מוחזרות ישר לוואטסאפ.</span>
        <span class="l-en">Six capabilities, one Hebrew message away — generated by Forly, delivered straight back into WhatsApp.</span>
      </p>
    </header>

    
    <div class="grid">
      {cards.map((c, i) => (
        <article class="card" data-card style={`--i:${i}`}>
          <div class="card-glow" data-card-glow></div>
          <div class="card-content">
            <p class="card-label"><T he={c.label.he} en={c.label.en} /></p>
            <h3 class="card-title"><T he={c.title.he} en={c.title.en} /></h3>
            <p class="card-body"><T he={c.body.he} en={c.body.en} /></p>
            <div class="card-meter">
              <div class="meter-row">
                <span class="meter-label"><T he={c.metricLabel.he} en={c.metricLabel.en} /></span>
                <span class="meter-value" data-meter-value data-target={c.metric}>0%</span>
              </div>
              <div class="meter-track">
                <div class="meter-fill" data-meter-fill data-target={c.metric}></div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Letter-by-letter scramble quote — each language gets its own scramble target. -->
    <blockquote class="scramble" data-scramble-block>
      <p class="scramble-text">
        <span class="l-he" data-scramble>הכל במקום אחד </span>
        <span class="l-en" data-scramble>No app. No dashboard. No design tools. Just WhatsApp.</span>
      </p>
      <cite><T he="— התזה של פורלי v2" en="— The Forly v2 thesis" /></cite>
    </blockquote>

    <!-- Counter strip — four accent-coded cards. Each stat owns a color,
         an icon, and a gradient numeral; hover lifts with a colored glow. -->
    <ul class="stats" data-stats>
      {stats.map((s) => (
        <li class:list={['stat', `stat--${s.accent}`]}>
          <span class="stat-icon" aria-hidden="true">
            {s.icon === 'spark' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7L12 3z" />
                <path d="M19 4l.6 1.7L21 6.3l-1.4.6L19 8.6l-.6-1.7L17 6.3l1.4-.6z" />
              </svg>
            )}
            {s.icon === 'palette' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21a9 9 0 110-18 9 9 0 015 16.4c-1.2.8-2.6.4-2.6-1 0-1.5 1.4-1.7 1.4-3 0-1-.9-1.6-2-1.6h-1.5a2 2 0 01-2-2c0-1.4.9-2.4-.3-3.3" />
                <circle cx="7.5" cy="11" r="1" fill="currentColor" />
                <circle cx="11" cy="7.5" r="1" fill="currentColor" />
                <circle cx="15.5" cy="8.5" r="1" fill="currentColor" />
              </svg>
            )}
            {s.icon === 'clock' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3.5 2" />
              </svg>
            )}
            {s.icon === 'globe' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <path d="M3 12h18" />
                <path d="M12 3a14 14 0 010 18" />
                <path d="M12 3a14 14 0 000 18" />
              </svg>
            )}
          </span>
          <span class="stat-num" data-counter data-target={s.value} data-suffix={s.suffix}>0</span>
          <span class="stat-label"><T he={s.he} en={s.en} /></span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Light theme — matches the RadialOrbitalTimeline above. Page surface
     (--surface = #fbf5f8) shows through; soft pink/sage radials add depth
     without changing the underlying color story. */
  .features {
    position: relative;
    padding: 160px 0 120px;
    background:
      radial-gradient(800px 600px at 20% 0%, rgba(219, 107, 151, 0.10), transparent 60%),
      radial-gradient(700px 500px at 80% 100%, rgba(127, 168, 155, 0.06), transparent 60%),
      var(--surface);
  }
  .features-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 72px;
    display: grid;
    gap: 18px;
  }
  .features-title {
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    color: var(--ink);
  }
  .grad {
    background: linear-gradient(110deg, var(--forli-pink-soft), var(--forli-pink), var(--forli-pink-deep));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .features-sub {
    color: var(--ink-soft);
    font-size: 17px;
    max-width: 560px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 1000px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .grid { grid-template-columns: 1fr; } }

  .card {
    position: relative;
    border-radius: var(--radius-md);
    padding: 1px;
    background: linear-gradient(180deg, rgba(26, 18, 32, 0.06), rgba(26, 18, 32, 0.02));
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .card-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      280px circle at var(--mx, 50%) var(--my, 50%),
      rgba(219, 107, 151, 0.18),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .card:hover .card-glow { opacity: 1; }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 40px rgba(26, 18, 32, 0.10);
  }

  .card-content {
    position: relative;
    z-index: 1;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-radius: calc(var(--radius-md) - 1px);
    padding: 28px 26px 26px;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .card-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--forli-pink-deep);
  }
  .card-title {
    font-size: 22px;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .card-body {
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.55;
    flex: 1;
  }

  .card-meter { display: grid; gap: 8px; margin-top: 6px; }
  .meter-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 12px;
    color: var(--ink-soft);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }
  .meter-value { color: var(--ink); font-weight: 600; }
  .meter-track {
    height: 4px;
    background: rgba(26, 18, 32, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }
  .meter-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--forli-pink-soft), var(--forli-pink));
    border-radius: 4px;
    box-shadow: 0 0 10px rgba(219, 107, 151, 0.45);
  }

  .scramble {
    margin: 140px auto 120px;
    max-width: 920px;
    text-align: center;
    display: grid;
    gap: 18px;
  }
  .scramble-text {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.4vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-shadow: 0 0 50px rgba(219, 107, 151, 0.18);
  }
  .scramble-text .ch { display: inline-block; }
  .scramble-text .ch.live { color: var(--forli-pink); }
  .scramble cite {
    font-style: normal;
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* Stats — four accent-coded cards. Each card owns a hue via --accent
     custom property and renders an icon, gradient numeral, and label. */
  .stats {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
    padding: 0;
    margin: 0;
    max-width: 720px;
    margin-inline: auto;
  }

  .stat {
    --accent: var(--forli-pink);
    --accent-soft: rgba(219, 107, 151, 0.12);
    --accent-glow: rgba(219, 107, 151, 0.28);
    --accent-ink: #6e1a3e;
    position: relative;
    padding: 30px 22px 24px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    display: grid;
    gap: 12px;
    justify-items: center;
    text-align: center;
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
  }
  /* Per-accent tokens. Picked so each hue stays in the warm/Mediterranean
     family and reads as professional rather than gaudy on the rose surface. */
  .stat--pink   { --accent: #db6b97; --accent-soft: rgba(219, 107, 151, 0.14); --accent-glow: rgba(219, 107, 151, 0.30); --accent-ink: #6e1a3e; }
  .stat--violet { --accent: #8b6bbd; --accent-soft: rgba(139, 107, 189, 0.14); --accent-glow: rgba(139, 107, 189, 0.30); --accent-ink: #3d2a66; }
  .stat--amber  { --accent: #d49a4f; --accent-soft: rgba(212, 154, 79, 0.16); --accent-glow: rgba(212, 154, 79, 0.32); --accent-ink: #6b4310; }
  .stat--sage   { --accent: #6d9a8b; --accent-soft: rgba(127, 168, 155, 0.18); --accent-glow: rgba(127, 168, 155, 0.32); --accent-ink: #2c4a3f; }

  /* Top accent stripe */
  .stat::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
  }
  /* Soft radial wash that hints at the card hue without overwhelming */
  .stat::after {
    content: '';
    position: absolute;
    inset: -40% -30% auto -30%;
    height: 75%;
    background: radial-gradient(closest-side, var(--accent-soft), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  .stat:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 14px 38px var(--accent-glow);
  }

  .stat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid color-mix(in oklab, var(--accent) 25%, transparent);
  }
  .stat-icon svg { width: 20px; height: 20px; }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    background: linear-gradient(160deg, var(--accent) 0%, var(--accent-ink) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 4px 14px var(--accent-glow));
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Reveal stagger on heading
  gsap.utils.toArray<HTMLElement>('[data-reveal-stagger]').forEach((group) => {
    const items = group.querySelectorAll<HTMLElement>('[data-reveal]');
    gsap.from(items, {
      y: 40,
      opacity: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.1,
      scrollTrigger: { trigger: group, start: 'top 80%' },
    });
  });

  // Card stagger reveal + meter fill on enter
  const cards = gsap.utils.toArray<HTMLElement>('[data-card]');
  if (cards.length) {
    gsap.from(cards, {
      y: 60,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.08,
      scrollTrigger: { trigger: cards[0].parentElement, start: 'top 75%' },
    });

    cards.forEach((card) => {
      const fill = card.querySelector<HTMLElement>('[data-meter-fill]');
      const value = card.querySelector<HTMLElement>('[data-meter-value]');
      if (!fill || !value) return;
      const target = Number(fill.dataset.target ?? 0);
      const proxy = { v: 0 };
      ScrollTrigger.create({
        trigger: card,
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.to(fill, { width: `${target}%`, duration: 1.4, ease: 'power3.out' });
          gsap.to(proxy, {
            v: target,
            duration: 1.4,
            ease: 'power3.out',
            onUpdate: () => {
              value.textContent = `${Math.round(proxy.v)}%`;
            },
          });
        },
      });
    });

    // Mouse-following neon glow on card hover
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      });
    });
  }

  // Letter-by-letter scramble reveal — applied independently to each language.
  const chars = '!<>-_\\/[]{}—=+*^?#________';
  document.querySelectorAll<HTMLElement>('[data-scramble]').forEach((scrambleEl) => {
    const original = scrambleEl.textContent ?? '';
    scrambleEl.innerHTML = original
      .split('')
      .map((c) => `<span class="ch" data-c="${c.replace(/"/g, '&quot;')}">${c === ' ' ? '&nbsp;' : c}</span>`)
      .join('');
    const spans = scrambleEl.querySelectorAll<HTMLElement>('.ch');

    ScrollTrigger.create({
      trigger: scrambleEl,
      start: 'top 75%',
      once: true,
      onEnter: () => {
        spans.forEach((span, i) => {
          const finalChar = span.dataset.c ?? '';
          if (finalChar === ' ') return;
          let frame = 0;
          const totalFrames = 14 + Math.floor(Math.random() * 8);
          const start = i * 22;
          setTimeout(() => {
            span.classList.add('live');
            const id = setInterval(() => {
              frame++;
              if (frame >= totalFrames) {
                span.textContent = finalChar;
                span.classList.remove('live');
                clearInterval(id);
              } else {
                span.textContent = chars[Math.floor(Math.random() * chars.length)];
              }
            }, 28);
          }, start);
        });
      },
    });
  });

  // Counter strip
  gsap.utils.toArray<HTMLElement>('[data-counter]').forEach((el) => {
    const target = Number(el.dataset.target ?? 0);
    const suffix = el.dataset.suffix ?? '';
    const obj = { v: 0 };
    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.to(obj, {
          v: target,
          duration: 1.8,
          ease: 'power3.out',
          onUpdate: () => {
            const n = target >= 1000 ? Math.round(obj.v).toLocaleString() : Math.round(obj.v).toString();
            el.textContent = `${n}${suffix}`;
          },
        });
      },
    });
  });
</script>
