---
import T from './T.astro';

const links = [
  { href: '#features', he: 'יכולות', en: 'Capabilities' },
  { href: '/faq', he: 'שאלות נפוצות', en: 'FAQ' },
  { href: '#cta', he: 'הצטרפו', en: 'Join beta' },
];
---
<header class="nav" data-nav>
  <div class="nav-inner">
    <a href="#top" class="brand" aria-label="Forly home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-name">FORLY</span>
    </a>
    <nav class="links" aria-label="Primary">
      {links.map((l) => <a href={l.href}><T he={l.he} en={l.en} /></a>)}
    </nav>
    <div class="nav-actions">
      <button type="button" class="lang-toggle" data-lang-toggle aria-label="Toggle language">
        <span class="l-he"><span class="lang-toggle-current">עב</span> · EN</span>
        <span class="l-en">HE · <span class="lang-toggle-current">EN</span></span>
      </button>
      <a href="#cta" class="btn btn-primary nav-cta">
        <T he="נסו בחינם" en="Try free" />
      </a>
    </div>
  </div>
</header>

<style>
  /* Match the Features section's dark aubergine palette + soft pink/sage radials. */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 16px 0;
    background:
      radial-gradient(600px 220px at 18% 50%, rgba(219, 107, 151, 0.16), transparent 65%),
      radial-gradient(500px 200px at 82% 50%, rgba(127, 168, 155, 0.10), transparent 65%),
      var(--aubergine-deep);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transform: translateY(0);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s ease, backdrop-filter 0.3s ease;
  }
  .nav[data-state='hidden'] { transform: translateY(-120%); }
  .nav[data-state='scrolled'] {
    background:
      radial-gradient(600px 220px at 18% 50%, rgba(219, 107, 151, 0.16), transparent 65%),
      radial-gradient(500px 200px at 82% 50%, rgba(127, 168, 155, 0.10), transparent 65%),
      rgba(26, 18, 32, 0.78);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .nav-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: 0.18em;
    font-size: 14px;
  }
  .brand-mark {
    width: 26px;
    height: 26px;
    border-radius: 8px;
    background: radial-gradient(circle at 30% 30%, var(--forli-pink-soft), var(--forli-pink) 60%, var(--forli-pink-deep));
    box-shadow: var(--glow-pink);
  }
  .brand-name { color: var(--white); }
  .links {
    display: flex;
    gap: 28px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.72);
  }
  .links a {
    position: relative;
    transition: color 0.2s ease;
  }
  .links a:hover { color: var(--white); }
  .links a::after {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-inline-end: 0;
    bottom: -6px;
    height: 1px;
    background: var(--forli-pink);
    transform: scaleX(0);
    transform-origin: var(--underline-origin, left);
    transition: transform 0.3s ease;
  }
  html[dir='rtl'] .links a::after { --underline-origin: right; }
  .links a:hover::after { transform: scaleX(1); }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .nav-cta { padding: 10px 20px; font-size: 13px; }

  /* Dark-theme override for the lang toggle — the global .lang-toggle rule
     was designed for the light surface; on the dark Nav it needs inverted
     border / background / text colors to stay legible. */
  .nav .lang-toggle {
    color: rgba(255, 255, 255, 0.72);
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.05);
  }
  .nav .lang-toggle:hover {
    color: var(--white);
    border-color: var(--forli-pink);
    background: rgba(255, 255, 255, 0.10);
  }
  .nav .lang-toggle .lang-toggle-current {
    color: var(--forli-pink-soft);
  }

  @media (max-width: 720px) {
    .links { display: none; }
    .lang-toggle { font-size: 10px; padding: 6px 10px; }
  }
</style>

<script>
  const nav = document.querySelector('[data-nav]') as HTMLElement | null;
  if (nav) {
    let last = 0;
    let ticking = false;
    const onScroll = () => {
      const y = window.scrollY;
      if (y > 40) nav.dataset.state = y > last && y > 240 ? 'hidden' : 'scrolled';
      else nav.dataset.state = '';
      last = y;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });
  }

  // Language toggle — flip <html lang/dir>, persist, swap title + description.
  const w = window as unknown as {
    __forlyLangTitles?: Record<string, string>;
    __forlyLangDescs?: Record<string, string>;
  };
  document.querySelectorAll<HTMLElement>('[data-lang-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const html = document.documentElement;
      const next = html.lang === 'he' ? 'en' : 'he';
      html.lang = next;
      html.dir = next === 'he' ? 'rtl' : 'ltr';
      try { localStorage.setItem('forly-lang', next); } catch {}
      const titles = w.__forlyLangTitles;
      const descs = w.__forlyLangDescs;
      if (titles && titles[next]) document.title = titles[next];
      const meta = document.querySelector('meta[name="description"]');
      if (meta && descs && descs[next]) meta.setAttribute('content', descs[next]);
    });
  });
</script>
