---
// WhatsApp-style chat input bubble. Reusable, location-agnostic.
// The parent is responsible for positioning + entrance/exit animation.
//
// Props
//   he   – Hebrew message text (required)
//   en   – English message text (optional; falls back to he if omitted)
//   dir  – 'rtl' | 'ltr' (default: 'rtl' — message text reads RTL by default)
import T from './T.astro';

const {
  he,
  en,
  dir = 'rtl',
} = Astro.props as { he: string; en?: string; dir?: 'rtl' | 'ltr' };
---
<div class="wa-input" role="presentation">
  <div class="wa-field" dir={dir}>
    <!-- emoji / smiley -->
    <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm-3.5-9a1.5 1.5 0 1 1 1.5-1.5A1.5 1.5 0 0 1 8.5 11zm7 0a1.5 1.5 0 1 1 1.5-1.5 1.5 1.5 0 0 1-1.5 1.5zm-3.5 6.5A5 5 0 0 1 7.5 13h9a5 5 0 0 1-4.5 4.5z"
      />
    </svg>

    <span class="wa-text">
      {en ? <T he={he} en={en} /> : he}
    </span>

    <!-- mic -->
    <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="M12 14a3 3 0 0 0 3-3V6a3 3 0 1 0-6 0v5a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.92V21h2v-3.08A7 7 0 0 0 19 11z"
      />
    </svg>

    <!-- camera -->
    <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="M20 4h-3.2L15 2H9L7.2 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm-8 13a5 5 0 1 1 5-5 5 5 0 0 1-5 5zm0-8a3 3 0 1 0 3 3 3 3 0 0 0-3-3z"
      />
    </svg>
  </div>

  <button class="wa-send" type="button" aria-hidden="true" tabindex="-1">
    <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
      <path fill="currentColor" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
    </svg>
  </button>
</div>

<style>
  .wa-input {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    font-family: 'Heebo', 'Inter', system-ui, sans-serif;
  }
  .wa-field {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: #ffffff;
    border-radius: 26px;
    box-shadow:
      0 1px 3px rgba(11, 20, 26, 0.08),
      0 8px 24px rgba(11, 20, 26, 0.06);
  }
  .wa-icon {
    flex: none;
    width: 22px;
    height: 22px;
    color: #54656f;
    opacity: 0.85;
  }
  .wa-text {
    flex: 1;
    color: #111b21;
    font-size: 16px;
    line-height: 1.3;
    text-align: start;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .wa-send {
    flex: none;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    background: #25d366;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 2px 6px rgba(37, 211, 102, 0.35),
      0 8px 22px rgba(37, 211, 102, 0.18);
    cursor: default;
    padding: 0;
  }
  /* Mirror the paper-plane in RTL pages so it visually points toward the
     "send direction" (end of the input). */
  html[dir='rtl'] .wa-send svg { transform: scaleX(-1); }

  @media (max-width: 720px) {
    .wa-text {
      font-size: 15px;
      /* Allow long Hebrew requests to wrap so they're not truncated to "..." */
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
      line-height: 1.45;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .wa-field { align-items: flex-start; padding: 12px 14px; }
    .wa-icon { margin-top: 2px; }
    .wa-send { width: 40px; height: 40px; }
  }
</style>
