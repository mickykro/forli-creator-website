---
// Vanilla-Astro port of the radial orbital timeline.
// Props: items[] with bilingual { he, en } content, status, relatedIds, progress.
// Auto-rotates while idle. Click a node → snaps it to top, expands a card,
// pulses related nodes. Click background → resumes auto-rotate.
import T from './T.astro';

export interface TimelineItemContent {
  title: string;
  content: string;
  date: string;
}

export interface TimelineItem {
  id: number;
  iconKey:
    | 'plan' | 'listen' | 'spark' | 'send' | 'refresh'
    | 'image' | 'image-edit' | 'video' | 'video-motion' | 'carousel' | 'website';
  he: TimelineItemContent;
  en: TimelineItemContent;
  status: 'completed' | 'in-progress' | 'pending';
  relatedIds: number[];
  progress: number; // 0–100
}

interface Props {
  items: TimelineItem[];
  headingHe?: string;
  headingEn?: string;
  eyebrowHe?: string;
  eyebrowEn?: string;
}

const {
  items,
  headingHe,
  headingEn,
  eyebrowHe,
  eyebrowEn,
} = Astro.props as Props;

// Bilingual status labels — embedded in the markup so both languages are
// available for the CSS-driven .l-he / .l-en swap.
const STATUS_LABEL = {
  completed:   { he: 'הושלם',   en: 'COMPLETE' },
  'in-progress': { he: 'בתהליך', en: 'IN PROGRESS' },
  pending:     { he: 'ממתין',   en: 'PENDING' },
} as const;
---
<section class="rot-section" aria-label={headingEn || 'Forly process timeline'}>
  {(headingHe || eyebrowHe) && (
    <header class="rot-head">
      {eyebrowHe && (
        <p class="eyebrow">
          <T he={eyebrowHe} en={eyebrowEn ?? eyebrowHe} />
        </p>
      )}
      {headingHe && (
        <h2 class="rot-title">
          <T he={headingHe} en={headingEn ?? headingHe} />
        </h2>
      )}
    </header>
  )}

  <div class="rot-stage" data-rot-stage>
    <!-- Central pulsing orb -->
    <div class="rot-core" aria-hidden="true">
      <span class="rot-core-ping"></span>
      <span class="rot-core-ping rot-core-ping-2"></span>
      <span class="rot-core-inner"></span>
    </div>

    <!-- Orbit ring -->
    <div class="rot-ring" aria-hidden="true"></div>

    <!-- Nodes (positioned by the script after mount) -->
    {items.map((item, i) => (
      <div
        class="rot-node"
        role="button"
        tabindex="0"
        data-rot-node
        data-id={item.id}
        data-index={i}
        data-related={item.relatedIds.join(',')}
        data-status={item.status}
        data-progress={item.progress}
        aria-label={`${i + 1}. ${item.en.title}`}
      >
        <span class="rot-node-glow" aria-hidden="true"></span>
        <span class="rot-node-dot" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16">
            {item.iconKey === 'plan' && (
              <path
                fill="currentColor"
                d="M19 4h-1V2h-2v2H8V2H6v2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"
              />
            )}
            {item.iconKey === 'listen' && (
              <path
                fill="currentColor"
                d="M12 14a3 3 0 0 0 3-3V6a3 3 0 1 0-6 0v5a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.92V21h2v-3.08A7 7 0 0 0 19 11z"
              />
            )}
            {item.iconKey === 'spark' && (
              <path
                fill="currentColor"
                d="M12 2l1.95 6.07L20 10l-6.05 1.93L12 18l-1.95-6.07L4 10l6.05-1.93L12 2zm6.5 11l1 3.1 3 1-3 1-1 3-1-3-3-1 3-1 1-3.1zM5.5 14l.75 2.4L8.5 17l-2.25.6L5.5 20l-.75-2.4L2.5 17l2.25-.6L5.5 14z"
              />
            )}
            {item.iconKey === 'send' && (
              <path
                fill="currentColor"
                d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"
              />
            )}
            {item.iconKey === 'refresh' && (
              <path
                fill="currentColor"
                d="M17.65 6.35A8 8 0 1 0 19.73 14h-2.08A6 6 0 1 1 12 6a5.91 5.91 0 0 1 4.22 1.78L13 11h7V4l-2.35 2.35z"
              />
            )}
            {item.iconKey === 'image' && (
              <path
                fill="currentColor"
                d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.9 13.98l2.1 2.53 3.1-3.99L18 18H6l2.9-4.02zM6.5 9.5a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0z"
              />
            )}
            {item.iconKey === 'image-edit' && (
              <path
                fill="currentColor"
                d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"
              />
            )}
            {item.iconKey === 'video' && (
              <path
                fill="currentColor"
                d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"
              />
            )}
            {item.iconKey === 'video-motion' && (
              <path
                fill="currentColor"
                d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM10 17V7l5 5-5 5z"
              />
            )}
            {item.iconKey === 'carousel' && (
              <path
                fill="currentColor"
                d="M2 7h3v10H2V7zm17 0h3v10h-3V7zM7 5h10c.55 0 1 .45 1 1v12c0 .55-.45 1-1 1H7c-.55 0-1-.45-1-1V6c0-.55.45-1 1-1z"
              />
            )}
            {item.iconKey === 'website' && (
              <path
                fill="currentColor"
                d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8h16v10zM5.5 6.75a.75.75 0 1 1 1.5 0 .75.75 0 0 1-1.5 0zm2 0a.75.75 0 1 1 1.5 0 .75.75 0 0 1-1.5 0zm2 0a.75.75 0 1 1 1.5 0 .75.75 0 0 1-1.5 0z"
              />
            )}
          </svg>
        </span>
        <span class="rot-node-label">
          <T he={item.he.title} en={item.en.title} />
        </span>

        <div class="rot-card" data-rot-card>
          <div class="rot-card-stem" aria-hidden="true"></div>
          <div class="rot-card-head">
            <span class={`rot-status rot-status-${item.status}`}>
              <T he={STATUS_LABEL[item.status].he} en={STATUS_LABEL[item.status].en} />
            </span>
            <span class="rot-card-date">
              <T he={item.he.date} en={item.en.date} />
            </span>
          </div>
          <h3 class="rot-card-title">
            <T he={item.he.title} en={item.en.title} />
          </h3>
          <p class="rot-card-body">
            <T he={item.he.content} en={item.en.content} />
          </p>
          {item.relatedIds.length > 0 && (
            <div class="rot-card-related">
              <p class="rot-card-related-head">
                <T he="שלבים מקושרים" en="Connected steps" />
              </p>
              <div class="rot-card-related-list">
                {item.relatedIds.map((rid) => {
                  const r = items.find((x) => x.id === rid);
                  if (!r) return null;
                  return (
                    <button
                      type="button"
                      class="rot-card-related-btn"
                      data-rot-jump={rid}
                    >
                      <T he={r.he.title} en={r.en.title} />
                      <span class="rot-card-related-arrow" aria-hidden="true">→</span>
                    </button>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .rot-section {
    position: relative;
    width: 100%;
    padding: 0px 0 40px;
  }
  .rot-head { 
    text-align: center;
    max-width: 680px;
    margin: 36px auto ;
    display: grid;
    gap: 0px;
    padding: 0 24px;
  }
  .rot-title {
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  /* Negative top margin pulls the orbit up under the heading. The stage
     is taller than its visible orbit (so cards have room to expand below
     the active node), which leaves dead space above the ring — this
     compensates for that. */
  .rot-stage {
    position: relative;
    width: 100%;
    max-width: 720px;
    height: 560px;
    margin: -80px auto 0;
    perspective: 1000px;
  }
  @media (max-width: 720px) {
    .rot-stage { margin-top: -56px; }
  }

  /* Central pulsing orb — pink instead of the original purple/teal so it
     fits the Forly palette. */
  .rot-core {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      var(--forli-pink-soft),
      var(--forli-pink) 55%,
      var(--forli-pink-deep)
    );
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--glow-pink-strong);
    z-index: 10;
    animation: rotPulse 2s ease-in-out infinite;
  }
  .rot-core-inner {
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.85);
    border-radius: 50%;
    backdrop-filter: blur(4px);
  }
  .rot-core-ping {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1px solid rgba(219, 107, 151, 0.45);
    animation: rotPing 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    opacity: 0.7;
  }
  .rot-core-ping-2 {
    inset: -22px;
    animation-delay: 0.6s;
    opacity: 0.5;
  }

  .rot-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 384px;
    height: 384px;
    border: 1px dashed rgba(26, 18, 32, 0.12);
    border-radius: 50%;
  }

  /* Each node is a positioned wrapper. The script sets its transform
     (translate to its current point on the orbit) every animation frame. */
  .rot-node {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    cursor: pointer;
    color: var(--ink);
    outline: none;
    transition: opacity 0.7s, z-index 0s;
    will-change: transform, opacity;
  }
  .rot-node:focus-visible .rot-node-dot {
    box-shadow: 0 0 0 3px rgba(219, 107, 151, 0.4);
  }

  .rot-node-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 70px;
    height: 70px;
    margin: -35px 0 0 -35px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(219, 107, 151, 0.25) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .rot-node[data-active='true'] .rot-node-glow,
  .rot-node[data-pulsing='true'] .rot-node-glow {
    opacity: 1;
  }

  .rot-node-dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 40px;
    height: 40px;
    margin: -20px 0 0 -20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--ink);
    color: var(--white);
    border: 2px solid rgba(255, 255, 255, 0.35);
    transition: transform 0.3s, background 0.3s, color 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .rot-node[data-active='true'] .rot-node-dot {
    background: var(--forli-pink);
    color: var(--white);
    border-color: var(--forli-pink);
    transform: scale(1.5);
    box-shadow: 0 0 24px rgba(219, 107, 151, 0.5), 0 0 60px rgba(219, 107, 151, 0.25);
  }
  .rot-node[data-pulsing='true'] .rot-node-dot {
    background: rgba(255, 255, 255, 0.9);
    color: var(--ink);
    border-color: var(--forli-pink);
    animation: rotPulse 1s ease-in-out infinite;
  }

  .rot-node-label {
    position: absolute;
    top: 28px;
    left: 0;
    transform: translateX(-50%);
    /* font-family: var(--font-mono); */
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
    color: #000000;
    transition: color 0.3s, transform 0.3s;
  }
  .rot-node[data-active='true'] .rot-node-label {
    color: var(--ink);
    transform: translateX(-50%) scale(1.15);
  }

  /* Card */
  .rot-card {
    position: absolute;
    top: 64px;
    left: 0;
    transform: translateX(-50%);
    width: 280px;
    padding: 16px 18px 18px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(16px);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    box-shadow: 0 14px 40px rgba(26, 18, 32, 0.12);
    text-align: start;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transform-origin: top center;
    transform: translateX(-50%) translateY(6px) scale(0.96);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .rot-node[data-active='true'] .rot-card {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .rot-card-stem {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 10px;
    background: var(--forli-pink);
    opacity: 0.5;
  }
  .rot-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .rot-status {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 999px;
    border: 1px solid;
  }
  .rot-status-completed {
    background: var(--ink);
    color: var(--white);
    border-color: var(--ink);
  }
  .rot-status-in-progress {
    background: var(--forli-pink);
    color: var(--white);
    border-color: var(--forli-pink);
  }
  .rot-status-pending {
    background: rgba(26, 18, 32, 0.04);
    color: var(--ink-soft);
    border-color: var(--line);
  }
  .rot-card-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
  }
  .rot-card-title {
    font-size: 17px;
    font-weight: 800;
    color: var(--ink);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .rot-card-body {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 14px;
  }
  .rot-card-related {
    border-top: 1px dashed var(--line);
    margin-top: 12px;
    padding-top: 10px;
  }
  .rot-card-related-head {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }
  .rot-card-related-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .rot-card-related-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink-soft);
    padding: 4px 8px;
    font-size: 11px;
    font-family: var(--font-mono);
    border-radius: 0;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .rot-card-related-btn:hover {
    color: var(--ink);
    border-color: var(--forli-pink);
    background: rgba(219, 107, 151, 0.08);
  }
  .rot-card-related-arrow { color: var(--forli-pink); }
  html[dir='rtl'] .rot-card-related-arrow { transform: scaleX(-1); }

  /* Animations */
  @keyframes rotPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }
  @keyframes rotPing {
    0% { transform: scale(1); opacity: 0.7; }
    75%, 100% { transform: scale(2); opacity: 0; }
  }

  @media (max-width: 720px) {
    .rot-section { padding: 56px 0 24px; }
    .rot-stage { height: 480px; max-width: 460px; }
    .rot-ring { width: 280px; height: 280px; }
    .rot-card { width: 240px; top: 56px; padding: 14px; }
    .rot-card-title { font-size: 15px; }
    .rot-card-body { font-size: 13px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .rot-core { animation: none; }
    .rot-core-ping { display: none; }
  }
</style>

<script>
  type Item = {
    id: number;
    index: number;
    related: number[];
    el: HTMLElement;
  };

  document.querySelectorAll<HTMLElement>('[data-rot-stage]').forEach((stage) => {
    const nodeEls = stage.querySelectorAll<HTMLElement>('[data-rot-node]');
    if (!nodeEls.length) return;

    const items: Item[] = Array.from(nodeEls).map((el, i) => ({
      id: Number(el.dataset.id),
      index: i,
      related: (el.dataset.related || '')
        .split(',')
        .filter(Boolean)
        .map(Number),
      el,
    }));
    const total = items.length;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let rotation = 0;
    let autoRotate = !reduceMotion;
    let activeId: number | null = null;
    let rafId = 0;

    const getRadius = () => {
      const ring = stage.querySelector<HTMLElement>('.rot-ring');
      return ring ? ring.offsetWidth / 2 : 192;
    };

    const positionNodes = () => {
      const radius = getRadius();
      for (const item of items) {
        const angle = ((item.index / total) * 360 + rotation) % 360;
        const radian = (angle * Math.PI) / 180;
        const x = radius * Math.cos(radian);
        const y = radius * Math.sin(radian);
        const isActive = activeId === item.id;
        const opacity = isActive
          ? 1
          : Math.max(0.4, Math.min(1, 0.4 + 0.6 * ((1 + Math.sin(radian)) / 2)));
        const z = isActive ? 300 : Math.round(100 + 50 * Math.cos(radian));
        item.el.style.transform = `translate(${x}px, ${y}px)`;
        item.el.style.opacity = String(opacity);
        item.el.style.zIndex = String(z);
      }
    };

    const tick = () => {
      if (autoRotate) {
        rotation = (rotation + 0.3) % 360;
        positionNodes();
      }
      rafId = requestAnimationFrame(tick);
    };

    const setActive = (id: number | null) => {
      activeId = id;
      autoRotate = id === null && !reduceMotion;

      const activeItem = id !== null ? items.find((x) => x.id === id) : null;
      const relatedSet = new Set(activeItem?.related ?? []);

      for (const item of items) {
        item.el.dataset.active = String(item.id === id);
        item.el.dataset.pulsing = String(relatedSet.has(item.id));
      }

      // Snap rotation so the active node sits at the top (270° in screen coords).
      if (activeItem) {
        const targetAngle = (activeItem.index / total) * 360;
        rotation = (270 - targetAngle + 360) % 360;
      }
      positionNodes();
    };

    // Click handlers
    for (const item of items) {
      item.el.addEventListener('click', (e) => {
        e.stopPropagation();
        setActive(activeId === item.id ? null : item.id);
      });
      item.el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          e.stopPropagation();
          setActive(activeId === item.id ? null : item.id);
        }
      });
    }

    // Connected-step jump buttons inside cards
    stage.querySelectorAll<HTMLElement>('[data-rot-jump]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const target = Number(btn.dataset.rotJump);
        if (Number.isFinite(target)) setActive(target);
      });
    });

    // Click outside any node to deselect
    stage.addEventListener('click', (e) => {
      if (e.target === stage) setActive(null);
    });

    positionNodes();
    if (!reduceMotion) rafId = requestAnimationFrame(tick);

    // Reposition on resize
    window.addEventListener('resize', positionNodes);
  });
</script>
