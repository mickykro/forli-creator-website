---
// The keratin carousel — the deliverable that matches the request in the
// Hero's WhatsApp bubble, staged as a 3D coverflow showpiece.
// Cards enter as a stacked deck of "fresh prints", fan out into a 3D arc,
// then autoplay. Drag / swipe / arrows / dots / keyboard all navigate.
import T from './T.astro';

const slides = [
  { src: '/keratin-carousel/slide-01.png', alt: { he: 'הוק: הלחות ניצחה אותך הקיץ? לא השנה.', en: 'Hook: Did the humidity beat you this summer? Not this year.' } },
  { src: '/keratin-carousel/slide-02.png', alt: { he: 'ההצעה: החלקת קרטין מקצועית — מחיר השקה השבוע בלבד', en: 'Offer: professional keratin straightening — launch price this week only' } },
  { src: '/keratin-carousel/slide-03.png', alt: { he: 'מה את מקבלת: מחזיק עד 4 חודשים, מראה טבעי, מותאם אישית', en: 'Benefits: holds up to 4 months, natural look, personalized' } },
  { src: '/keratin-carousel/slide-04.png', alt: { he: 'המקומות האחרונים לשבוע הזה', en: 'Last spots for this week' } },
  { src: '/keratin-carousel/slide-05.png', alt: { he: 'CTA — שלחי "קרטין" בוואטסאפ', en: 'CTA — send "keratin" on WhatsApp' } },
];
---
<section class="cp-section" id="carousel-preview" aria-labelledby="cp-heading">
  <header class="cp-head">
    <p class="eyebrow">
      <T he="הפלט המלא · 30 שניות" en="Full output · 6 seconds" />
    </p>
    <h2 id="cp-heading" class="cp-title">
      <span class="l-he">זה מה שפורלי החזירה.</span>
      <span class="l-en">This is what Forly returned.</span>
    </h2>
    <p class="cp-sub">
      <span class="l-he">קרוסלה של 5 סלייידים — מוכנה להעלאה לאינסטגרם.</span>
      <span class="l-en">A 5-slide carousel — ready to post to Instagram.</span>
    </p>
  </header>

  <div class="cf-stage" data-cf-stage tabindex="0" role="region"
       aria-roledescription="carousel" aria-label="Keratin carousel preview">
    <div class="cf-glow" aria-hidden="true"></div>

    <div class="cf-track" data-cf-track>
      {slides.map((slide, i) => (
        <figure class="cf-card" data-cf-card data-i={i} role="group"
                aria-label={`${i + 1} / ${slides.length}`}>
          <span class="cp-num">{String(i + 1).padStart(2, '0')}</span>
          <img
            src={slide.src}
            alt={slide.alt.en}
            width="540"
            height="540"
            loading="lazy"
            decoding="async"
            draggable="false"
          />
          <span class="cf-sheen" aria-hidden="true"></span>
        </figure>
      ))}
    </div>

    <!-- Floor shadow under the stage -->
    <div class="cf-floor" aria-hidden="true"></div>

    <button class="cf-arrow cf-prev" data-cf-prev aria-label="Previous slide">‹</button>
    <button class="cf-arrow cf-next" data-cf-next aria-label="Next slide">›</button>
  </div>

  <div class="cf-controls">
    <span class="cf-counter" aria-hidden="true">
      <span data-cf-cur>01</span><span class="cf-counter-sep">/</span><span>{String(slides.length).padStart(2, '0')}</span>
    </span>
    <div class="cf-dots" data-cf-dots role="tablist" aria-label="Slides">
      {slides.map((_, i) => (
        <button class="cf-dot" data-cf-dot data-i={i} role="tab"
                aria-label={`Slide ${i + 1}`}>
          <span class="cf-dot-fill"></span>
        </button>
      ))}
    </div>
    <span class="cf-hint">
      <span class="l-he">גררו · לחצו · החליקו</span>
      <span class="l-en">Drag · click · swipe</span>
    </span>
  </div>

  <footer class="cp-foot">
    <p class="cp-caption" dir="rtl">
      <span class="l-he">
        <strong>הלחות ניצחה אותך הקיץ? לא השנה 💕</strong><br/>
        החלקת קרטין מקצועית — השבוע בלבד במחיר השקה. שיער חלק, זורם וטבעי שמחזיק חודשים — בלי פריזז, בלי בלגן, רק קיץ קליל.<br/>
        מקומות אחרונים — שלחי "קרטין" בהודעה ✨
      </span>
      <span class="l-en">
        <strong>Did the humidity beat you this summer? Not this year 💕</strong><br/>
        Professional keratin straightening — launch price, this week only. Smooth, flowing, natural hair that holds for months — no frizz, no chaos, just an effortless summer.<br/>
        Last spots — DM "keratin" ✨
      </span>
    </p>
    <p class="cp-tags">#החלקתקרטין&nbsp; #שיערחלק&nbsp; #מבצעהשקה&nbsp; #קיץ2026&nbsp; #ביוטי</p>
  </footer>
</section>

<style>
  .cp-section {
    position: relative;
    background: linear-gradient(180deg, var(--bg, #fff) 0%, #fef6ef 100%);
    padding: clamp(56px, 8vw, 96px) 0 clamp(48px, 7vw, 72px);
    overflow: hidden;
  }

  .cp-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 8px;
    display: grid;
    gap: 12px;
    padding: 0 24px;
  }
  .cp-title {
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .cp-sub {
    font-size: clamp(15px, 1.6vw, 17px);
    color: var(--ink-soft);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ── 3D stage ─────────────────────────────────────────────────────── */
  .cf-stage {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    height: clamp(340px, 46vw, 560px);
    perspective: 1400px;
    outline: none;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }
  .cf-glow {
    position: absolute;
    inset: -10% -20%;
    pointer-events: none;
    background:
      radial-gradient(46% 56% at 50% 52%, rgba(219, 107, 151, 0.16), transparent 70%),
      radial-gradient(30% 40% at 30% 40%, rgba(167, 139, 250, 0.10), transparent 70%);
    filter: blur(10px);
  }
  .cf-track {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
  }
  .cf-card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(240px, 30vw, 400px);
    aspect-ratio: 1 / 1;
    margin: 0;
    border-radius: var(--radius-md, 16px);
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(26, 18, 32, 0.08);
    box-shadow:
      0 24px 60px rgba(26, 18, 32, 0.16),
      0 4px 14px rgba(26, 18, 32, 0.08);
    cursor: pointer;
    will-change: transform, filter, opacity;
    transition:
      transform 0.85s cubic-bezier(0.22, 0.9, 0.24, 1),
      filter 0.85s cubic-bezier(0.22, 0.9, 0.24, 1),
      opacity 0.85s ease,
      box-shadow 0.85s ease;
    backface-visibility: hidden;
  }
  .cf-card.is-active {
    cursor: grab;
    box-shadow:
      0 36px 90px rgba(219, 107, 151, 0.30),
      0 8px 24px rgba(26, 18, 32, 0.12);
  }
  .cf-card.is-active:active { cursor: grabbing; }
  .cf-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }
  /* Glossy sheen that sweeps across the card whenever it becomes active */
  .cf-sheen {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.55) 48%,
      rgba(255, 255, 255, 0.18) 54%,
      transparent 68%
    );
    transform: translateX(-130%);
    opacity: 0;
  }
  .cf-card.is-active .cf-sheen {
    animation: cf-sheen-sweep 1.1s cubic-bezier(0.3, 0.6, 0.3, 1) 0.35s 1 both;
  }
  @keyframes cf-sheen-sweep {
    0%   { transform: translateX(-130%); opacity: 1; }
    100% { transform: translateX(130%);  opacity: 1; }
  }

  .cp-num {
    position: absolute;
    top: 10px;
    left: 12px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.16em;
    padding: 4px 8px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--ink, #1a1220);
    border-radius: 999px;
    backdrop-filter: blur(4px);
    z-index: 2;
    font-weight: 700;
  }

  /* Elliptical floor shadow grounds the whole stage */
  .cf-floor {
    position: absolute;
    left: 50%;
    bottom: -4%;
    width: min(70%, 760px);
    height: 50px;
    transform: translateX(-50%);
    background: radial-gradient(50% 50% at 50% 50%, rgba(26, 18, 32, 0.16), transparent 70%);
    filter: blur(10px);
    pointer-events: none;
  }

  /* Arrows */
  .cf-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 30;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid var(--line, rgba(26, 18, 32, 0.08));
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    color: var(--ink, #1a1220);
    font-size: 26px;
    line-height: 1;
    display: grid;
    place-items: center;
    box-shadow: 0 8px 24px rgba(26, 18, 32, 0.10);
    transition: background 0.25s, transform 0.25s, color 0.25s;
  }
  .cf-arrow:hover {
    background: var(--forli-pink, #db6b97);
    color: #fff;
    transform: translateY(-50%) scale(1.08);
  }
  .cf-prev { left: clamp(8px, 3vw, 40px); }
  .cf-next { right: clamp(8px, 3vw, 40px); }

  /* ── Controls row: counter · dots · hint ─────────────────────────── */
  .cf-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 22px;
    margin-top: 18px;
  }
  .cf-counter {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--ink-soft, #5a4f65);
    font-variant-numeric: tabular-nums;
    /* Keep "02/05" reading order stable inside the RTL page */
    direction: ltr;
  }
  .cf-counter [data-cf-cur] { color: var(--forli-pink-deep, #b94c79); font-weight: 700; }
  .cf-counter-sep { margin: 0 5px; opacity: 0.4; }

  .cf-dots { display: flex; gap: 8px; }
  .cf-dot {
    position: relative;
    width: 8px;
    height: 8px;
    padding: 0;
    border-radius: 999px;
    background: rgba(219, 107, 151, 0.22);
    overflow: hidden;
    transition: width 0.4s cubic-bezier(0.22, 0.9, 0.24, 1), background 0.3s;
  }
  .cf-dot.is-active { width: 34px; }
  .cf-dot-fill {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: var(--forli-pink, #db6b97);
    transform: scaleX(0);
    transform-origin: left center;
  }
  .cf-dot.is-active .cf-dot-fill {
    animation: cf-progress var(--cf-delay, 4.5s) linear 1 both;
  }
  :global([dir='rtl']) .cf-dot-fill { transform-origin: right center; }
  .cf-dots.is-paused .cf-dot-fill { animation-play-state: paused; }
  @keyframes cf-progress { from { transform: scaleX(0); } to { transform: scaleX(1); } }

  .cf-hint {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-soft, #5a4f65);
    opacity: 0.7;
  }

  /* ── Caption footer ───────────────────────────────────────────────── */
  .cp-foot {
    max-width: 720px;
    margin: 40px auto 0;
    padding: 24px 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--line, rgba(26, 18, 32, 0.08));
    border-radius: var(--radius-md, 16px);
    backdrop-filter: blur(8px);
  }
  .cp-caption {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink, #1a1220);
    margin: 0 0 12px;
  }
  .cp-caption strong { font-weight: 700; }
  .cp-tags {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--forli-pink, #db6b97);
    margin: 0;
    direction: ltr;
    text-align: center;
  }

  @media (max-width: 720px) {
    .cf-stage { height: clamp(300px, 96vw, 420px); }
    .cf-card { width: min(72vw, 320px); }
    .cf-arrow { display: none; }
    .cf-hint { display: none; }
    .cp-foot { margin: 28px 16px 0; padding: 18px 20px; }
    .cp-caption { font-size: 14px; line-height: 1.6; }
    .cp-tags { font-size: 11px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cf-card { transition: none; }
    .cf-card.is-active .cf-sheen { animation: none; }
  }
</style>

<script>
  // 3D coverflow: deck entrance → fan-out → autoplay with progress dots.
  const stage = document.querySelector<HTMLElement>('[data-cf-stage]');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-cf-card]'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('[data-cf-dot]'));
  const dotsWrap = document.querySelector<HTMLElement>('[data-cf-dots]');
  const curEl = document.querySelector<HTMLElement>('[data-cf-cur]');
  const prevBtn = document.querySelector<HTMLElement>('[data-cf-prev]');
  const nextBtn = document.querySelector<HTMLElement>('[data-cf-next]');

  if (stage && cards.length) {
    const N = cards.length;
    const AUTOPLAY_MS = 4500;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    stage.style.setProperty('--cf-delay', `${AUTOPLAY_MS}ms`);
    dotsWrap?.style.setProperty('--cf-delay', `${AUTOPLAY_MS}ms`);

    let active = 0;
    let live = false; // becomes true after the deck fans out

    const metrics = () => {
      const w = cards[0].offsetWidth;
      const narrow = window.innerWidth <= 720;
      return {
        shiftX: w * (narrow ? 0.46 : 0.56), // horizontal step per slot
        depth: narrow ? 110 : 150,          // px pushed back per slot
        rot: narrow ? 24 : 30,              // deg of Y rotation per slot
      };
    };

    const layout = () => {
      const { shiftX, depth, rot } = metrics();
      cards.forEach((card, i) => {
        const d = i - active;
        const ad = Math.abs(d);
        card.style.transform =
          `translate(-50%, -50%) ` +
          `translateX(${d * shiftX}px) ` +
          `translateZ(${-ad * depth}px) ` +
          `rotateY(${-d * rot}deg) ` +
          `scale(${1 - ad * 0.06})`;
        card.style.zIndex = String(20 - ad);
        card.style.filter = ad === 0 ? 'none' : `brightness(${1 - ad * 0.10}) saturate(${1 - ad * 0.12})`;
        card.style.opacity = ad > 2 ? '0.35' : '1';
        card.classList.toggle('is-active', d === 0);
        card.setAttribute('aria-hidden', d === 0 ? 'false' : 'true');
      });
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === active));
      if (curEl) curEl.textContent = String(active + 1).padStart(2, '0');
    };

    const goTo = (i: number) => {
      active = ((i % N) + N) % N;
      layout();
      restartAutoplay();
    };
    const next = () => goTo(active + 1);
    const prev = () => goTo(active - 1);

    // ── Autoplay (progress is the active dot's fill animation) ──
    let timer: number | null = null;
    const stopAutoplay = () => { if (timer) { clearInterval(timer); timer = null; } };
    const startAutoplay = () => {
      if (reduceMotion || timer) return;
      timer = window.setInterval(() => { active = (active + 1) % N; layout(); resetDotProgress(); }, AUTOPLAY_MS);
    };
    const resetDotProgress = () => {
      // Re-trigger the fill animation on the (new) active dot
      const fill = dots[active]?.querySelector<HTMLElement>('.cf-dot-fill');
      if (!fill) return;
      fill.style.animation = 'none';
      void fill.offsetWidth;
      fill.style.animation = '';
    };
    const restartAutoplay = () => { stopAutoplay(); resetDotProgress(); startAutoplay(); };

    stage.addEventListener('pointerenter', () => { stopAutoplay(); dotsWrap?.classList.add('is-paused'); });
    stage.addEventListener('pointerleave', () => { dotsWrap?.classList.remove('is-paused'); if (live) startAutoplay(); });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopAutoplay();
      else if (live) startAutoplay();
    });

    // ── Input: click cards, arrows, dots, keyboard, drag/swipe ──
    cards.forEach((card, i) => card.addEventListener('click', () => { if (i !== active) goTo(i); }));
    prevBtn?.addEventListener('click', prev);
    nextBtn?.addEventListener('click', next);
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    stage.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); next(); }
      if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
    });

    let dragX: number | null = null;
    stage.addEventListener('pointerdown', (e) => { dragX = e.clientX; });
    window.addEventListener('pointerup', (e) => {
      if (dragX === null) return;
      const dx = e.clientX - dragX;
      dragX = null;
      if (Math.abs(dx) > 36) (dx < 0 ? next : prev)();
    });

    window.addEventListener('resize', () => { if (live) layout(); });

    // ── Entrance: stacked deck → fan out when scrolled into view ──
    if (reduceMotion) {
      live = true;
      layout();
    } else {
      // Initial: all cards piled in the center like fresh prints
      cards.forEach((card, i) => {
        const tilt = (i - (N - 1) / 2) * 2.4;
        card.style.transform =
          `translate(-50%, -50%) translateY(24px) rotate(${tilt}deg) translateZ(${-i * 6}px)`;
        card.style.zIndex = String(N - i);
        card.style.opacity = '0';
      });
      const io = new IntersectionObserver(
        (entries) => {
          if (!entries.some((en) => en.isIntersecting)) return;
          io.disconnect();
          // Reveal the pile, hold a beat, then fan out
          cards.forEach((card) => { card.style.opacity = '1'; });
          setTimeout(() => {
            live = true;
            layout();
            resetDotProgress();
            startAutoplay();
          }, 650);
        },
        { threshold: 0.35 },
      );
      io.observe(stage);
    }
  }
</script>
